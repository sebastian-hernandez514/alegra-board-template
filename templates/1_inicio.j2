  const months = ['Jan-25','Feb-25','Mar-25','Apr-25','May-25','Jun-25','Jul-25','Aug-25','Sep-25','Oct-25','Nov-25','Dec-25','Jan-26','Feb-26','Mar-26'];

  /* ---------- Panel 1: ARR EoP ---------- */
  const arrSpot  = [19.3, 20.9, 22.4, 22.0, 22.5, 22.9, 23.5, 23.5, 24.2, 24.7, 25.6, 26.6, 27.0, 26.8, 27.3];
  const arrConst = [21.5, 22.7, 24.2, 24.3, 24.6, 24.6, 24.9, 25.2, 25.5, 26.0, 27.0, 27.0, 26.6, 27.3, 27.3];

  new Chart(document.getElementById('arrEoP'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        { label: 'Spot FX',              data: arrSpot,  backgroundColor: '#185FA5', borderRadius: 2, maxBarThickness: 16 },
        { label: 'Constant Currency FX', data: arrConst, backgroundColor: '#94a3b8', borderRadius: 2, maxBarThickness: 16 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      layout: { padding: { top: 14, right: 6, left: 4, bottom: 0 } },
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      scales: {
        x: { grid: { display: false }, border: { display: false },
             ticks: { color: '#64748b', font: { family: 'DM Sans', size: 9, weight: '500' } } },
        y: { display: false, beginAtZero: true, max: 32 }
      }
    },
    plugins: [{
      id: 'arrEoPLabels',
      afterDatasetsDraw(chart) {
        const {ctx} = chart;
        ctx.save();
        ctx.font = "500 8.5px 'DM Mono', monospace";
        ctx.textAlign = 'center';
        const spotBars  = chart.getDatasetMeta(0).data;
        const constBars = chart.getDatasetMeta(1).data;
        spotBars.forEach((bar, i) => {
          ctx.fillStyle = '#185FA5';
          ctx.fillText(arrSpot[i].toFixed(1), bar.x, bar.y - 4);
        });
        constBars.forEach((bar, i) => {
          ctx.fillStyle = '#475569';
          ctx.fillText(arrConst[i].toFixed(1), bar.x, bar.y - 4);
        });
        ctx.restore();
      }
    }]
  });

  /* ---------- Panel 2: Net New ARR ---------- */
  const newAdds     = [ 600,  800,  700,  800,  800,  800,  900,  800,  800,  800,  800, 1000, 1000, 1000, 1200];
  const upsellsNet  = [   0, 1400, 1400,  300,  300,  200,  300,  200,  300,  200,  400,  800,  100, -100,    0];
  const disconnects = [-800,-1000, -700,-1000, -800, -900, -800, -800, -800, -800, -800, -800,-1200,-1300, -800];
  const fxImpact    = [ 300,  600,    0, -500,  300,  300,  300,    0,  500,  200,  400,    0,  500,  200, -300];
  const netNew      = [ 100, 1600, 1400, -400,  600,  400,  600,    0,  800,  500,  900, 1000,  500, -200,  400];

  new Chart(document.getElementById('netNew'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        { label: 'New Adds',              data: newAdds,     backgroundColor: '#185FA5', stack: 'abs', borderRadius: 1, maxBarThickness: 26 },
        { label: 'Upsells / (Downsells)', data: upsellsNet,  backgroundColor: '#94a3b8', stack: 'abs', borderRadius: 1, maxBarThickness: 26 },
        { label: 'Disconnects',           data: disconnects, backgroundColor: '#5EEAD4', stack: 'abs', borderRadius: 1, maxBarThickness: 26 },
        { label: 'FX',                    data: fxImpact,    backgroundColor: '#0f172b', stack: 'abs', borderRadius: 1, maxBarThickness: 26 },
        { type: 'line', label: 'Net New', data: netNew,
          borderColor: '#E11D48', backgroundColor: '#E11D48',
          tension: 0, pointRadius: 3, borderWidth: 1.5,
          borderDash: [4, 3], order: 0 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      layout: { padding: { top: 10, right: 6, left: 10, bottom: 0 } },
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      scales: {
        x: { stacked: true, grid: { color: 'rgba(15,23,43,.04)', drawTicks: false },
             border: { color: '#cbd5e1' },
             ticks: { color: '#64748b', font: { family: 'DM Sans', size: 9, weight: '500' } } },
        y: { stacked: true, beginAtZero: true, min: -2000, max: 2500,
             grid: { color: 'rgba(128,128,128,.10)' }, border: { display: false },
             ticks: { color: '#94a3b8', font: { family: 'DM Mono', size: 9 }, stepSize: 500,
               callback: v => v === 0 ? '0' : (v < 0 ? '\u2212' : '') + Math.abs(v).toLocaleString('en-US')
             }}
      }
    }
  });
})();
</script>

</body>
</html>
