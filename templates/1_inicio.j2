<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alegra Board — Inicio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../styles/base.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <style>
    /* ============================================================
       KS — Key Summary Metrics (Monthly + YTD)
       DM Sans / DM Mono — prefix .ks- for CSS isolation
       ============================================================ */
    .ks-content {
      flex: 1;
      padding: 20px 48px 0;
      display: flex;
      flex-direction: column;
      font-family: 'DM Sans', sans-serif;
    }
    .ks-slide-tag {
      font-size: 10px; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: #999; margin-bottom: 10px;
    }
    .ks-headline {
      font-size: 12px; font-weight: 500; color: #fff;
      border-radius: 8px; padding: 9px 16px;
      margin-bottom: 16px; line-height: 1.55; letter-spacing: 0.01em;
    }
    .ks-headline-blue  { background: #0e3d5c; }
    .ks-headline-green { background: #0b4d3a; }
    .ks-headline-red   { background: #5C2100; }
    .ks-track-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #eaf3de; border-radius: 20px; padding: 4px 12px;
      font-size: 11px; color: #3b6d11; font-weight: 500; margin-bottom: 14px;
    }
    .ks-track-dot { width: 7px; height: 7px; background: #639922; border-radius: 50%; }
    .ks-sec-label {
      font-size: 10px; font-weight: 600; color: #bbb;
      text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 8px;
    }
    .ks-divider { border: none; border-top: 0.5px solid #e8e6df; margin: 14px 0; }
    /* Primary row */
    .ks-p-row { display: grid; grid-template-columns: 1.5fr 1fr 1fr; }
    .ks-p-cell { padding-right: 28px; }
    .ks-p-cell:not(:first-child) { padding-left: 28px; padding-right: 0; border-left: 0.5px solid #e8e6df; }
    .ks-p-name { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 4px; }
    .ks-p-val    { font-size: 40px; font-weight: 500; color: #0e3d5c; line-height: 1; margin-bottom: 8px; letter-spacing: -0.02em; }
    .ks-p-val-sm { font-size: 34px; font-weight: 500; color: #0e3d5c; line-height: 1; margin-bottom: 8px; letter-spacing: -0.02em; }
    .ks-p-val-green { color: #0b4d3a; }
    /* Delta */
    .ks-d-compact { display: flex; flex-direction: column; gap: 3px; }
    .ks-d-line { display: flex; align-items: baseline; font-size: 11px; line-height: 1.3; }
    .ks-tags { display: flex; gap: 4px; flex-wrap: wrap; align-items: baseline; }
    .ks-d-tag-pill { font-size: 10px; font-weight: 500; color: #bbb; background: #f5f4f0; border-radius: 4px; padding: 1px 5px; letter-spacing: 0.04em; font-family: 'DM Mono', monospace; }
    .ks-d-sep { font-size: 10px; color: #ddd; margin: 0 2px; }
    .ks-pos { color: #1d9e75; font-weight: 500; }
    .ks-neg { color: #d85a30; font-weight: 500; }
    .ks-neu { color: #888;    font-weight: 500; }
    /* Secondary row */
    .ks-sec-row { display: grid; grid-template-columns: 1fr 1fr 1fr; }
    .ks-sec-cell { padding-right: 24px; }
    .ks-sec-cell:not(:first-child) { padding-left: 24px; padding-right: 0; border-left: 0.5px solid #e8e6df; }
    .ks-sec-name { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 4px; }
    .ks-sec-val  { font-size: 24px; font-weight: 500; color: #444; margin-bottom: 6px; letter-spacing: -0.01em; }
    /* Tertiary */
    .ks-ter-row { display: flex; gap: 12px; margin-bottom: 14px; }
    .ks-ter-cell { border-radius: 10px; padding: 10px 14px; flex: 1; }
    /* Compact variant for dense slides */
    .ks-compact { padding-top: 12px !important; }
    .ks-compact .ks-divider { margin: 8px 0; }
    .ks-compact .ks-ter-row { margin-bottom: 8px; }
    .ks-compact .ks-ter-cell { padding: 7px 12px; }
    .ks-compact .ks-ter-val { font-size: 18px; }
    .ks-compact .ks-sec-label { margin-bottom: 4px; }
    .ks-compact .ks-headline { margin-bottom: 10px; padding: 8px 14px; font-size: 11px; }
    .ks-ter-cell-blue  { background: #f3f6f9; }
    .ks-ter-cell-green { background: #f0f6f3; }
    .ks-ter-name { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 4px; }
    .ks-ter-val       { font-size: 20px; font-weight: 500; margin-bottom: 2px; letter-spacing: -0.01em; }
    .ks-ter-val-blue  { color: #0e3d5c; }
    .ks-ter-val-green { color: #0b4d3a; }
    .ks-ter-val-risk  { color: #d85a30; }
    .ks-ter-val-muted { color: #666; }
    .ks-ter-d { font-size: 11px; color: #999; line-height: 1.5; }
    /* Insights */
    .ks-ins       { border-radius: 10px; padding: 12px 16px; }
    .ks-ins-blue  { background: #eef3f8; }
    .ks-ins-green { background: #eef5f2; }
    .ks-ins-title { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: #bbb; margin-bottom: 8px; }
    .ks-ins-item  { font-size: 11.5px; color: #4a4a47; line-height: 1.6; display: flex; gap: 8px; margin-bottom: 4px; }
    .ks-ins-item:last-child { margin-bottom: 0; }
    .ks-dot       { width: 5px; height: 5px; border-radius: 50%; margin-top: 7px; flex-shrink: 0; }
    .ks-dot-blue  { background: #0e3d5c; }
    .ks-dot-green { background: #0b4d3a; }
    /* ============================================================
       ARR Walk Summary — slide 6
       ============================================================ */
    .aw-sum-wrap {
      flex: 1; padding: 6px 90px 0;
      overflow: hidden; display: flex; flex-direction: column; gap: 4px;
    }
    .aw-sum-headline {
      background: #0f172b; border-radius: 5px; padding: 7px 18px; flex-shrink: 0;
    }
    .aw-sum-headline p { font-size: 11.5px; font-weight: 400; color: #a8bdd0; line-height: 1.55; }
    .aw-sum-headline strong { color: #ffffff; font-weight: 700; }
    .aw-sum-headline .hg { color: #30b8b7; font-weight: 600; }
    .aw-sum-headline .ha { color: #E87722; font-weight: 600; }

    .aw-sum-table { width: 100%; border-collapse: collapse; }
    .aw-sum-table thead tr { border-bottom: 1.5px solid #e2e8f0; }
    .aw-sum-table thead th {
      text-align: right; font-size: 9.5px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8;
      padding: 3px 7px 5px; white-space: nowrap;
    }
    .aw-sum-table thead th:first-child { text-align: left; padding-left: 4px; width: 200px; }
    .aw-sum-table thead th.aw-cur {
      color: #208080; background: rgba(48,184,183,0.09); border-radius: 4px 4px 0 0;
    }
    .aw-sum-table thead th.aw-dh { font-size: 9px; color: #cbd5e1; }
    .aw-sum-table thead th.aw-ytd { font-size: 9px; color: #94a3b8; font-weight: 700; }

    .aw-sum-table tbody td {
      text-align: right; padding: 0 7px; height: 17px;
      font-family: 'DM Mono', monospace; font-size: 10px; color: #475569;
      white-space: nowrap; vertical-align: middle; border-bottom: 1px solid #f1f5f9;
    }
    .aw-sum-table tbody td:first-child {
      text-align: left; font-family: 'DM Sans', sans-serif;
      font-weight: 500; font-size: 11px; color: #475569; padding-left: 4px;
    }
    .aw-sum-table tbody td.aw-cur { background: rgba(48,184,183,0.07); color: #1a7e7f; font-weight: 600; }

    tr.aw-rb td {
      font-weight: 700 !important; color: #1e293b !important;
      font-family: 'DM Sans', sans-serif !important; font-size: 10.5px !important;
      border-bottom: 1.5px solid #e2e8f0 !important; height: 19px !important;
    }
    tr.aw-rb td:first-child { color: #0f172b !important; }
    tr.aw-rb td.aw-cur { color: #1a7e7f !important; font-weight: 700 !important; background: rgba(48,184,183,0.09); }

    tr.aw-in td:first-child { padding-left: 20px; font-size: 10.5px; font-weight: 400; color: #64748b; }
    tr.aw-cc td { border-top: 1px dashed #cbd5e1 !important; }
    tr.aw-cc td:first-child { color: #0f172b !important; font-weight: 600 !important; font-size: 10.5px; }

    tr.aw-sh td {
      height: 15px !important; font-family: 'DM Sans', sans-serif !important;
      font-weight: 700 !important; font-size: 8.5px !important;
      text-transform: uppercase; letter-spacing: 1.4px; color: #0f172b !important;
      border-top: 1.5px solid #e2e8f0 !important; border-bottom: none !important;
      background: #f8fafc; padding-top: 3px !important;
    }
    tr.aw-sh td.aw-cur { background: rgba(48,184,183,0.07); color: #1a7e7f !important; }
    tr.aw-sh td:not(.aw-cur):not(:first-child) { background: #f8fafc; }

    tr.aw-rt td {
      height: 14px !important; font-size: 9.5px !important;
      color: #94a3b8 !important; border-bottom: 1px solid transparent !important;
    }
    tr.aw-rt td:first-child { font-size: 10px !important; color: #94a3b8 !important; font-style: italic; padding-left: 20px; }
    tr.aw-rt td.aw-cur { color: #299e9c !important; }
    tr.aw-gap td { height: 3px; padding: 0; border: none !important; background: transparent !important; }

    tr.aw-delta-sub td { font-size:10px; color:#64748b; font-weight:400; border-bottom:none; height:15px !important; }
    tr.aw-delta-sub td:first-child { padding-left:20px; text-align:left; font-size:10px; font-weight:400; color:#64748b; }
    tr.aw-delta-sub td.aw-cur { background:rgba(48,184,183,0.07); }
    .awdp { display:inline-block; font-family:'DM Sans',sans-serif; font-size:9.5px; font-weight:600; border-radius:4px; padding:1px 5px; line-height:1.45; }
    .awdp-b { background:rgba(24,95,165,0.10); color:#185FA5; }
    .awdp-o { background:rgba(232,119,34,0.10); color:#E87722; }
    .awdp-n { background:#f1f5f9; color:#64748b; }
    .aw-nv { color:#E87722 !important; }
    .aw-di { display:inline-block; width:6px; height:6px; border-radius:50%; margin-right:5px; vertical-align:middle; }
    .aw-di-t { background:#30b8b7; } .aw-di-b { background:#185FA5; }
    .aw-di-o { background:#E87722; } .aw-di-s { background:#cbd5e1; }

    /* ── Global Country Performance (slide 7) ── */
    .cp-slide { display: flex; flex-direction: column; }
    .cp-slide .slide-header { background: #0f172b; padding: 13px 40px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .cp-slide .slide-header .title { color: #fff; font-size: 15px; font-weight: 600; }
    .cp-slide .slide-header .period { color: #14b8a6; font-size: 12px; font-weight: 500; }
    .aw-slide .slide-header { padding: 13px 40px; }
    .aw-slide .slide-header .title { font-size: 15px; font-weight: 600; }
    .aw-slide .slide-header .period { font-size: 12px; }
    .cp-inner { padding: 14px 28px 10px; display: flex; flex-direction: column; gap: 9px; }
    .bf-cards { display: flex; border-bottom: 1px solid #eaeaea; flex-shrink: 0; }
    .bf-card { flex: 1; padding: 13px 36px; text-align: center; }
    .bf-card:first-child { border-right: 1px solid #eaeaea; }
    .bf-card-label { font-size: 11px; font-weight: 700; letter-spacing: .08em; margin-bottom: 4px; }
    .bf-card-label.c { color: #534AB7; } .bf-card-label.l { color: #1D9E75; }
    .bf-card-value { font-size: 32px; font-weight: 800; color: #111; margin: 2px 0; letter-spacing: -1.5px; }
    .bf-card-sub { font-size: 11px; color: #888; }
    .bf-pos { color: #1D9E75; } .bf-neg { color: #D85A30; }
    .bf-table { padding: 4px 14px 0; overflow: hidden; }
    .bf-table table { width: 100%; border-collapse: collapse; }
    .bf-table thead th { font-size: 9px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #bbb; padding: 3px 8px 7px; border-bottom: 1px solid #eaeaea; }
    .bf-table th.right { text-align: right; } .bf-table th.left { text-align: left; } .bf-table th.center { text-align: center; }
    .bf-table tbody tr { border-bottom: 1px solid #f4f4f4; }
    .bf-table tbody tr:last-child { border-bottom: none; }
    .bf-table tbody tr.alert-row { background: rgba(216,90,48,0.05); }
    .bf-table td { padding: 6px 8px; font-size: 11px; vertical-align: middle; }
    .bf-table .metric-col { text-align: center; border-left: 1px solid #f0f0f0; border-right: 1px solid #f0f0f0; padding: 6px 12px; }
    .bf-table .metric-name { font-size: 10px; color: #888; font-weight: 500; white-space: nowrap; }
    .bf-table .metric-name.primary { color: #222; font-weight: 700; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: middle; }
    .sd-green { background: #1D9E75; } .sd-red { background: #D85A30; } .sd-amber { background: #E8A020; } .sd-gray { background: #ccc; }
    .bf-table .val { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600; color: #111; white-space: nowrap; }
    .bf-table .val.alert { color: #D85A30; }
    .bf-table .delta { font-size: 10px; white-space: nowrap; color: #bbb; }
    .bf-table .pos { color: #1D9E75; } .bf-table .neg { color: #D85A30; } .bf-table .neutral { color: #444; }
    .bf-table td.right { text-align: right; } .bf-table td.left { text-align: left; }
    /* ============================================================
       HL — Highlights / Lowlights (slide 2, layout expandido)
       ============================================================ */
    .hl-outer-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 28px;
      flex: 1;
      align-items: start;
    }
    .hl-items-2col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 14px;
    }
    .hl-item-sm {
      display: flex;
      gap: 7px;
      margin-bottom: 5px;
      font-size: 9.5px;
      line-height: 1.42;
      color: var(--color-text-secondary);
    }
    .hl-item-sm .hl-dot {
      margin-top: 5px;
    }
    .hl-lead-pos { color: #0f172b; font-weight: 600; }
    .hl-lead-neg { color: #0f172b; font-weight: 600; }
    .hl-financial {
      border-top: 1px solid #e2e8f0;
      margin-top: 10px;
      padding-top: 8px;
    }
    .hl-col-title.financial { color: #1d4ed8; border-color: #1d4ed8; }
    .hl-financial-label {
      font-size: 9px; font-weight: 700; color: #0f172b;
      text-transform: uppercase; letter-spacing: 1.2px;
      margin-bottom: 5px;
    }
    .hl-financial-text {
      font-size: 9px; line-height: 1.48; color: #475569;
    }

    /* ============================================================
       ARR Overview (slide 4) — prefix .arr2-
       ============================================================ */
    .arr2-body {
      flex: 1; overflow: hidden;
      padding: 8px 28px 4px;
      display: flex; flex-direction: column;
    }
    .arr2-section-header {
      background: #28c4b8; color: #fff;
      font-size: 11px; font-weight: 700; letter-spacing: 0.2px;
      padding: 4px 14px; border-radius: 3px; margin-bottom: 5px; flex-shrink: 0;
    }
    .arr2-section-header sup { font-size: 8px; }
    .arr2-chart-wrap { position: relative; flex-shrink: 0; }
    .arr2-c1 { height: 140px; }
    .arr2-c2 { height: 200px; }
    .arr2-footnote { font-size: 9px; color: #6b7280; padding: 2px 0 0; flex-shrink: 0; }
    .arr2-divider { border: none; border-top: 1px solid #e5e7eb; margin: 5px 0; flex-shrink: 0; }
    .arr2-legend { display: flex; justify-content: center; gap: 16px; font-size: 9.5px; color: #4b5563; margin-top: 4px; flex-shrink: 0; }
    .arr2-legend span { display: inline-flex; align-items: center; gap: 5px; }
    .arr2-legend .sw { display: inline-block; width: 10px; height: 10px; border-radius: 2px; }
  </style>
</head>
<body>

  <!-- ============================================================
       SLIDE 1 — Cover
       ============================================================ -->
  <div class="slide slide-cover">
    <div class="cover-eyebrow">Alegra · Confidential</div>
    <div class="cover-title">{% if metrics.is_quarter_end %}Quarterly{% else %}Monthly{% endif %} Business<br>Review</div>
    <div class="cover-subtitle">{% if metrics.is_quarter_end %}{{ config.quarter_label }}{% else %}{{ config.month_label }}{% endif %} Performance</div>
    <div class="cover-logo">Alegra</div>
  </div>

  <div class="slide-divider">↓ &nbsp; 2 / 7</div>

  <!-- ============================================================
       SLIDE 2 — CEO Highlights / Lowlights
       ============================================================ -->
  <div class="slide">
    <div class="slide-header">
      <span class="title">{{ editorial.ceo_title }}</span>
      <span class="period">{% if metrics.is_quarter_end %}{{ config.quarter_label }}{% else %}{{ config.month_label }}{% endif %}</span>
    </div>
    <div class="slide-body" style="padding-top: 20px; padding-bottom: 16px;">
      <div class="hl-outer-grid">

        <!-- Highlights — 2 sub-columnas para 8 items -->
        <div>
          <div class="hl-col-title positive">✦ &nbsp;Highlights</div>
          {% for item in editorial.highlights %}
          <div class="hl-item-sm">
            <div class="hl-dot positive"></div>
            <div>{{ item | hl_split('hl-lead-pos') | safe }}</div>
          </div>
          {% endfor %}
        </div>

        <!-- Lowlights + Financial Update -->
        <div>
          <div class="hl-col-title negative">▼ &nbsp;Lowlights</div>
          {% for item in editorial.lowlights %}
          <div class="hl-item-sm">
            <div class="hl-dot negative"></div>
            <div>{{ item | hl_split('hl-lead-neg') | safe }}</div>
          </div>
          {% endfor %}
          {% if editorial.financial_update %}
          <div class="hl-financial">
            <div class="hl-col-title financial">$ &nbsp;Financial Update</div>
            <div class="hl-financial-text">{{ editorial.financial_update }}</div>
          </div>
          {% endif %}
        </div>

      </div>
    </div>
    <div class="slide-footer">
      <span class="footer-brand">Alegra · Confidential</span>
      <span class="footer-page">2</span>
    </div>
  </div>

  <div class="slide-divider">↓ &nbsp; 3 / 7</div>

  <!-- ============================================================
       SLIDE 3 — Table of Contents
       ============================================================ -->
  <div class="slide">
    <div class="slide-header">
      <span class="title">Table of Contents</span>
      <span class="period">{% if metrics.is_quarter_end %}{{ config.quarter_label }}{% else %}{{ config.month_label }}{% endif %}</span>
    </div>
    <div class="slide-body" style="padding-top: 32px; padding-bottom: 32px; justify-content: center;">
      <div style="display: flex; flex-direction: column; gap: 18px; max-width: 560px; width: 100%;">
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">01</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">Key Summary Metrics</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">02</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">Discussion Topic</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">03</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">ARR Walk</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">04</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">Financial Overview</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">05</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">Go to Market</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">06</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">R&amp;D Investment</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">07</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">Headcount Summary</span>
        </div>
        <div style="display: flex; align-items: center; gap: 20px;">
          <span style="font-size: 12px; font-weight: 700; color: var(--color-teal); letter-spacing: 1px; min-width: 24px;">08</span>
          <span style="font-size: 15px; font-weight: 600; color: var(--color-text-primary);">Appendix</span>
        </div>
      </div>
    </div>
    <div class="slide-footer">
