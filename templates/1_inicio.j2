          <tbody>
            {% for row in metrics.global_country.butterfly_rows %}
            {% set is_alert = row.metric_name in ['Net New ARR', 'Churn Rate'] %}
            {% set dot_class = 'sd-red' if row.metric_name in ['Net New ARR', 'Churn Rate'] else ('sd-amber' if row.metric_name in ['CAC', 'Logos Growth'] else ('sd-gray' if row.metric_name == 'ARPA' else 'sd-green')) %}
            {% set is_primary = row.metric_name in ['New ARR', 'Net New ARR', 'Churn Rate'] %}
            {% set neutral_delta = row.metric_name == 'Investment' %}
            {% set invert_delta = row.metric_name in ['Churn Rate', 'CAC'] %}
            <tr{% if is_alert %} class="alert-row"{% endif %}>
              <td class="delta {{ 'neutral' if neutral_delta else ('pos' if (not row.core.yoy_positive if invert_delta else row.core.yoy_positive) else 'neg') }} right">{{ row.core.yoy }}</td>
              <td class="delta {{ 'neutral' if neutral_delta else ('pos' if (not row.core.mom_positive if invert_delta else row.core.mom_positive) else 'neg') }} right">{{ row.core.mom }}</td>
              <td class="val{{ ' alert' if row.core.val_negative else '' }} right">{{ row.core.val }}</td>
              <td class="metric-col"><span class="status-dot {{ dot_class }}"></span><span class="metric-name{{ ' primary' if is_primary else '' }}">{{ row.metric_name }}</span></td>
              <td class="val{{ ' alert' if row.lite.val_negative else '' }} left" style="padding-left:16px;">{{ row.lite.val }}</td>
              <td class="delta {{ 'neutral' if neutral_delta else ('pos' if (not row.lite.mom_positive if invert_delta else row.lite.mom_positive) else 'neg') }} right">{{ row.lite.mom }}</td>
              <td class="delta {{ 'neutral' if neutral_delta else ('pos' if (not row.lite.yoy_positive if invert_delta else row.lite.yoy_positive) else 'neg') }} right">{{ row.lite.yoy }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    <div class="slide-footer">
      <span class="footer-brand">Alegra · Confidential</span>
      <span class="footer-page">8</span>
    </div>
  </div>

<script>
(function(){
  Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
  Chart.defaults.font.size = 9;
  Chart.defaults.color = '#64748b';

  const months = ['Jan-25','Feb-25','Mar-25','Apr-25','May-25','Jun-25','Jul-25','Aug-25','Sep-25','Oct-25','Nov-25','Dec-25','Jan-26','Feb-26','Mar-26'];

  /* ---------- Panel 1: ARR EoP (Alegra + Alanube) ---------- */
  const alegraSpot  = [19.33,20.94,22.35,21.95,22.53,22.94,23.53,23.49,24.24,24.72,25.61,26.59,27.05,26.84,27.29];
  const alegraCC    = [21.54,22.67,24.21,24.27,24.56,24.63,24.94,24.94,25.24,25.52,26.02,27.03,26.98,26.57,27.29];
  const alanubeSpot = [364078,312013,330253,380487,416879,441827,552085,529985,504917,807412,631976,633027,616780,830995,955172].map(v=>+(v/1e6).toFixed(4));
  const alanubeCC   = [389035,326406,348128,405167,438495,462151,576649,550536,516491,828499,637183,638182,615854,825851,955172].map(v=>+(v/1e6).toFixed(4));
  const totalSpot   = alegraSpot.map((v,i) => +(v + alanubeSpot[i]).toFixed(2));
  const totalCC     = alegraCC.map((v,i)   => +(v + alanubeCC[i]).toFixed(2));

  const xAxis = {
    grid: { display: false }, border: { display: false },
    ticks: { font: { size: 9, family: 'Inter' }, color: '#4b5563', maxRotation: 0, padding: 4 }
  };

  new Chart(document.getElementById('arrEoP'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        { label: 'Spot FX',              data: totalSpot, backgroundColor: '#1e3a6e', barPercentage: 0.72, categoryPercentage: 0.62, borderRadius: 2 },
        { label: 'Constant Currency FX', data: totalCC,   backgroundColor: '#9db3c8', barPercentage: 0.72, categoryPercentage: 0.62, borderRadius: 2 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      layout: { padding: { top: 16 } },
      plugins: {
        legend: { display: false },
        tooltip: { mode: 'index', callbacks: { label: c => ` ${c.dataset.label}: ${c.parsed.y.toFixed(2)} Mn` } }
      },
      scales: {
        x: xAxis,
        y: { min: 0, grid: { color: '#e5e7eb', lineWidth: 0.5 }, border: { display: false },
             ticks: { font: { size: 9.5, family: 'Inter' }, color: '#4b5563', callback: v => v.toFixed(0) } }
      }
    },
    plugins: [{
      id: 'arrEoPLabels',
      afterDatasetsDraw(chart) {
        const { ctx } = chart;
        ctx.save();
        ctx.font = '700 9px Arial'; ctx.fillStyle = '#1f2937';
        ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
        chart.data.datasets.forEach((ds, di) => {
          chart.getDatasetMeta(di).data.forEach((bar, i) => {
            ctx.fillText(ds.data[i].toFixed(1), bar.x, bar.y - 2);
          });
        });
        ctx.restore();
      }
    }]
  });

  /* ---------- Panel 2: Net New ARR (Excludes Alanube) ---------- */
  const newAdds      = [616,748,762,798,770,756,828,757,796,820,883,993,970,969,1172];
  const netChurn     = [-808,-1010,-741,-991,-733,-863,-792,-915,-791,-781,-830,-831,-1121,-1265,-878];
  const netExpansion = [8,1313,1425,257,227,173,259,163,278,235,438,835,101,-125,426];
  const fxImpact     = [323,555,-29,-463,310,350,291,-43,470,200,403,-21,511,214,-275];
  const netNew       = [139,1606,1418,-399,574,416,585,-38,752,475,894,975,462,-207,445];

  new Chart(document.getElementById('netNew'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        { label: 'New Adds',                       data: newAdds,      backgroundColor: '#1e3a6e', stack: 'main', barPercentage: 0.72, categoryPercentage: 0.62, order: 2 },
        { label: 'Upsells / (Downsells)',           data: netExpansion, backgroundColor: '#8fa8c4', stack: 'main', barPercentage: 0.72, categoryPercentage: 0.62, order: 2 },
        { label: 'Disconnects',                     data: netChurn,     backgroundColor: '#2dd4bf', stack: 'main', barPercentage: 0.72, categoryPercentage: 0.62, order: 2 },
        { label: 'FX Appreciation / (Depreciation)',data: fxImpact,     backgroundColor: '#1a1a2e', stack: 'main', barPercentage: 0.72, categoryPercentage: 0.62, order: 2 },
        { type: 'line', label: 'Net New', data: netNew, borderColor: '#dc2626', borderDash: [5,4], borderWidth: 2, pointRadius: 0, pointHoverRadius: 3, fill: false, tension: 0.15, order: 1 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        tooltip: { mode: 'index', callbacks: { label: c => ` ${c.dataset.label}: ${Math.round(c.parsed.y).toLocaleString()}` } }
      },
      scales: {
        x: xAxis,
        y: { stacked: true, grid: { color: '#e5e7eb', lineWidth: 0.5 }, border: { display: false },
             ticks: { font: { size: 9.5, family: 'Inter' }, color: '#4b5563',
               callback: v => Math.abs(v) >= 1000 ? (v/1000).toFixed(0)+'k' : v } }
      }
    }
  });
})();
</script>

</body>
</html>
