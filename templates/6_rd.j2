          <tr class="pp-metric"><td>Avg Ticket New Additions</td><td class="pp-blue">$24.90</td><td class="pp-blue">$24.17</td><td class="pp-blue">$29.32</td><td class="pp-blue">$26.44</td><td class="pp-blue">$30.23</td><td class="pp-blue">$30.83</td></tr>
          <tr class="pp-metric"><td>% of Core Subscribers</td><td class="pp-red">35.00%</td><td class="pp-red">35.00%</td><td class="pp-red">35.00%</td><td class="pp-red">35.00%</td><td class="pp-red">35.00%</td><td class="pp-red">35.00%</td></tr>
          <tr class="pp-gap"><td colspan="7"></td></tr>

          <!-- POS (id_product=4 — Alegra POS) -->
          <tr class="pp-product">
