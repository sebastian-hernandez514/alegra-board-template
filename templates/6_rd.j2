          <tr class="pp-metric"><td>Churn rate %</td><td class="pp-teal">3.94%</td><td class="pp-teal">4.23%</td><td class="pp-teal">4.23%</td><td class="pp-teal">5.01%</td><td class="pp-teal">6.31%</td><td class="pp-teal">5.29%</td></tr>
          <tr class="pp-metric"><td>Avg Ticket New Additions</td><td class="pp-blue">$10.75</td><td class="pp-blue">$9.87</td><td class="pp-blue">$10.63</td><td class="pp-blue">$11.76</td><td class="pp-blue">$13.97</td><td class="pp-blue">$14.17</td></tr>
