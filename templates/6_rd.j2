          </tr>
          <tr class="pp-metric"><td>% of total Logos</td><td class="pp-teal">19.9%</td><td class="pp-teal">19.8%</td><td class="pp-teal">19.7%</td><td class="pp-teal">20.0%</td><td class="pp-teal">20.0%</td><td class="pp-teal">20.0%</td></tr>
          <tr class="pp-metric"><td>Churn rate %</td><td class="pp-teal">6.02%</td><td class="pp-teal">6.66%</td><td class="pp-teal">6.04%</td><td class="pp-teal">7.16%</td><td class="pp-teal">7.78%</td><td class="pp-teal">6.92%</td></tr>
