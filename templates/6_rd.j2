<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alegra Board — R&D Investment</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../styles/base.css">
  <style>
    .section-cover {
      background: var(--color-navy);
      justify-content: center;
      padding: var(--slide-pad-y) var(--slide-pad-x);
    }
    .section-cover .eyebrow {
      font-size: 11px; font-weight: 600; color: var(--color-teal);
      letter-spacing: 2px; text-transform: uppercase; margin-bottom: 14px;
    }
    .section-cover .section-title {
      font-size: 42px; font-weight: 700; color: #ffffff;
      letter-spacing: -1.5px; line-height: 1.05; margin-bottom: 14px;
    }
    .section-cover .section-sub {
      font-size: 15px; font-weight: 400; color: rgba(255,255,255,0.40);
    }
    .section-cover .slide-num {
      position: absolute; bottom: 24px; right: var(--slide-pad-x);
      font-size: 10px; color: rgba(255,255,255,0.15);
    }
    /* ── Product Performance table ── */
    .pp-body {
      flex: 1; padding: 8px 56px 8px;
      display: flex; flex-direction: column; gap: 4px; overflow: hidden;
    }
    .pp-table { width: 100%; border-collapse: collapse; font-family: 'DM Mono', monospace; }
    .pp-table thead th {
      text-align: right; font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8;
      padding: 2px 7px 4px; white-space: nowrap;
      border-bottom: 1.5px solid #e2e8f0;
    }
    .pp-table thead th:first-child { text-align: left; padding-left: 4px; min-width: 170px; }
    .pp-section td {
      font-family: 'Inter', sans-serif; font-size: 9.5px; font-weight: 700;
      color: #0d9488; background: #f0fdfa; padding: 2px 7px;
      border-top: 1.5px solid #e2e8f0; border-bottom: 1px solid #ccfbf1;
      letter-spacing: 0.3px; text-transform: uppercase;
    }
    .pp-product td {
      font-family: 'Inter', sans-serif; font-size: 10.5px; font-weight: 600;
      color: #0f172b; background: #f8fafc; padding: 2px 7px;
      border-top: 1.5px solid #e2e8f0; border-bottom: 0.5px solid #e2e8f0;
      text-align: right;
    }
    .pp-product td:first-child { text-align: left; }
    .pp-metric td {
      font-size: 10px; color: #64748b; padding: 1px 7px;
      border-bottom: 1px solid #f1f5f9; text-align: right; white-space: nowrap;
    }
    .pp-metric td:first-child { text-align: left; font-style: italic; padding-left: 12px; }
    .pp-gap td { padding: 1px 0; border: none; }
    .pp-total td {
      font-family: 'Inter', sans-serif; font-size: 10.5px; font-weight: 600;
      color: #0f172b; padding: 2px 7px; text-align: right;
      border-top: 1.5px solid #e2e8f0; border-bottom: 0.5px solid #e2e8f0;
    }
    .pp-total td:first-child { text-align: left; }
    .pp-teal  { color: #0d9488 !important; }
    .pp-blue  { color: #185FA5 !important; }
    .pp-red   { color: #C04828 !important; }

    .placeholder-inner {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 10px;
    }
    .placeholder-label {
      font-size: 13px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 1px; color: #cbd5e1;
    }
    .placeholder-note { font-size: 12px; color: #94a3b8; }
  </style>
</head>
<body>

  <!-- ============================================================
       SLIDE 1 — Section Cover
       ============================================================ -->
  <div class="slide section-cover">
    <div class="eyebrow">Section 06</div>
    <div class="section-title">R&amp;D Investment</div>
