  <script>
    /* ── Slide 2 sparklines ── */
    function spark(id, data, color, fill) {
      const ctx = document.getElementById(id);
      if (!ctx) return;
      const mn = Math.min(...data) * 0.992;
      const mx = Math.max(...data) * 1.008;
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: {{ metrics.hc.spark_labels | tojson }},
          datasets: [{ data, borderColor: color, borderWidth: 1.8,
            pointRadius: 0, fill: true, backgroundColor: fill, tension: 0.4 }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: { x: { display: false }, y: { display: false, min: mn, max: mx } },
          animation: { duration: 600, easing: 'easeOutQuart' }
        }
      });
    }

    {% for team in metrics.hc.teams %}
    spark('{{ team.spark_id }}', {{ team.spark_data | tojson }}, '{{ team.spark_color }}', '{{ team.spark_fill }}');
    {% endfor %}
    spark('sp_tot', {{ metrics.hc.total_spark_data | tojson }}, '#D85A30', 'rgba(216,90,48,0.05)');

    /* ── Slide 3 — People & Talent charts ── */
    (function() {
      const months     = ['Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar'];
      const newHires   = [22, 23, 18, 12,  9, 11, 11, 14, 15, 12, 19, 18,  7];
      const attrition  = [26,  6, 18,  8, 10, 11, 13, 21, 12, 15, 13, 17, 20];
      const peopleEoP  = [510, 530, 530, 535, 535, 525, 520, 520, 525, 520, 517, 515, 505];
      const turnover   = [4.8, 1.1, 3.5, 1.5, 1.6, 1.8, 2.4, 3.5, 2.0, 3.1, 2.76, 2.96, 3.84];
      const attrPct    = [5.3, 1.1, 3.5, 1.4, 2.3, 2.1, 2.4, 4.0, 2.1, 3.4, 3.68, 3.30, 3.96];

      Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
      Chart.defaults.font.size   = 9;
      Chart.defaults.color       = '#64748B';

      const commonLine = (max, title) => ({
        responsive: true, maintainAspectRatio: false, animation: false,
        layout: { padding: { top: 14, right: 12, left: 4, bottom: 2 } },
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: {
          x: { display: false, grid: { display: false } },
          y: {
            beginAtZero: true, max,
            ticks: { color: '#94A3B8', stepSize: Math.ceil(max / 4) },
            grid: { color: '#F1F5F9' }, border: { display: false },
            title: { display: true, text: title, color: '#64748B', font: { size: 8.5, weight: '600' } }
          }
        }
      });

      const commonBars = (max, title, pctAxis) => ({
        responsive: true, maintainAspectRatio: false, animation: false,
        layout: { padding: { top: 6, right: 12, left: 4, bottom: 2 } },
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#64748B', font: { size: 7.5 } }, border: { color: '#E2E8F0' } },
          y: {
            beginAtZero: true, max,
            ticks: { color: '#94A3B8', stepSize: pctAxis ? 1 : Math.ceil(max / 6), callback: v => pctAxis ? v + '%' : v },
            grid: { color: '#F1F5F9' }, border: { display: false },
            title: { display: true, text: title, color: '#64748B', font: { size: 8.5, weight: '600' } }
          }
        }
      });

      // LEFT TOP: New Hires + Attrition lines
      new Chart(document.getElementById('pt2LeftTop'), {
        type: 'line',
        data: {
          labels: months,
          datasets: [
            { label: 'New Hires', data: newHires, borderColor: '#30ABA9', backgroundColor: '#30ABA9', tension: 0.25, pointRadius: 2, borderWidth: 2 },
            { label: 'Attrition', data: attrition, borderColor: '#F43F5E', backgroundColor: '#F43F5E', tension: 0.25, pointRadius: 2, borderWidth: 2 }
          ]
        },
        options: commonLine(30, 'New Hires & Attrition'),
        plugins: [{
          id: 'pt2LblLT',
          afterDatasetsDraw(chart) {
            const {ctx} = chart;
            ctx.save(); ctx.font = '600 7.5px Inter';
            const hires = chart.getDatasetMeta(0).data;
            const attr  = chart.getDatasetMeta(1).data;
            [10,11,12].forEach(i => {
              const p = hires[i]; if (!p) return;
              ctx.fillStyle = '#1A7E7F'; ctx.textAlign = 'center';
              ctx.fillText(newHires[i], p.x, p.y + 12);
            });
            [10,11,12].forEach(i => {
              const p = attr[i]; if (!p) return;
              ctx.fillStyle = '#E11D48'; ctx.textAlign = 'center';
              ctx.fillText(attrition[i], p.x, p.y - 6);
            });
            ctx.restore();
          }
        }]
      });

      // LEFT BOTTOM: People EoP bars
      new Chart(document.getElementById('pt2LeftBot'), {
        type: 'bar',
        data: {
          labels: months,
          datasets: [{ label: 'People EoP', data: peopleEoP, backgroundColor: '#1E293B', borderRadius: 2, maxBarThickness: 22 }]
        },
        options: commonBars(600, 'People EoP', false),
        plugins: [{
          id: 'pt2LblLB',
          afterDatasetsDraw(chart) {
            const {ctx} = chart;
            ctx.save(); ctx.font = '600 7px Inter';
            const bars = chart.getDatasetMeta(0).data;
            [10,11,12].forEach(i => {
              const b = bars[i]; if (!b) return;
              ctx.fillStyle = '#FFFFFF'; ctx.textAlign = 'center';
              ctx.fillText(peopleEoP[i], b.x, b.y + 14);
            });
            ctx.restore();
          }
        }]
      });

      // RIGHT TOP: Turnover rate line
      new Chart(document.getElementById('pt2RightTop'), {
        type: 'line',
        data: {
          labels: months,
          datasets: [{ label: 'Turnover Rate', data: turnover, borderColor: '#F43F5E', backgroundColor: '#F43F5E', tension: 0.25, pointRadius: 2, borderWidth: 2 }]
        },
        options: commonLine(5, 'Staff Turnover Rate'),
        plugins: [{
          id: 'pt2LblRT',
          afterDatasetsDraw(chart) {
            const {ctx} = chart;
            ctx.save(); ctx.font = '600 7.5px Inter';
            const pts = chart.getDatasetMeta(0).data;
            [10,11,12].forEach(i => {
              const p = pts[i]; if (!p) return;
              ctx.fillStyle = '#E11D48'; ctx.textAlign = 'center';
              const dy = (i === 12) ? -7 : 12;
              ctx.fillText(turnover[i].toFixed(2).replace('.', ','), p.x, p.y + dy);
            });
            ctx.restore();
          }
        }]
      });

      // RIGHT BOTTOM: Attrition % bars
      new Chart(document.getElementById('pt2RightBot'), {
        type: 'bar',
        data: {
          labels: months,
          datasets: [{ label: 'Attrition %', data: attrPct, backgroundColor: '#1E293B', borderRadius: 2, maxBarThickness: 22 }]
        },
        options: commonBars(6, 'Attrition %', true),
        plugins: [{
          id: 'pt2LblRB',
          afterDatasetsDraw(chart) {
            const {ctx} = chart;
            ctx.save(); ctx.font = '600 7px Inter';
            const bars = chart.getDatasetMeta(0).data;
            [10,11,12].forEach(i => {
              const b = bars[i]; if (!b) return;
              ctx.fillStyle = '#FFFFFF'; ctx.textAlign = 'center';
              ctx.fillText(attrPct[i].toFixed(2).replace('.', ',') + '%', b.x, b.y + 14);
            });
            ctx.restore();
          }
        }]
      });
    })();
  </script>

