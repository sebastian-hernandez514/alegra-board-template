    const sectorCore   = [8.69, 5.11, 4.82, 4.54, 4.39, 4.06, 4.06, 3.69, 3.44, 3.39];
    const sectorLite   = [11.96, 8.42, 8.57, 8.05, 8.23, 6.42, 8.30, 6.61, 7.23, 8.64];

    const invoiceMonths = ['M−6','M−5','M−4','M−3','M−2','M−1'];
    const invoiceVol    = [54, 49, 44, 42, 38, 29];
    const invoiceDel    = [36, 31, 29, 28, 29, 24];

    const coreDel = [482, 557, 438, 497, 458, 457, 402, 449, 455, 495, 554, 606, 720, 737, 714];
