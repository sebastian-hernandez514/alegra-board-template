            y: { stacked: true, display: false }
          }
        },
        plugins: [{
          id: 'barLbl',
          afterDatasetsDraw(chart) {
            const { ctx, scales: { x, y } } = chart;
            ctx.save();
            show.forEach(i => {
              const xp = x.getPixelForValue(i);
              const total = su[i];
              const logo  = logos[i];
              const topY  = y.getPixelForValue(total);
              ctx.textAlign = 'center';
              ctx.font = `400 8px ${fmlMono}`;
              ctx.fillStyle = '#888780';
              ctx.fillText(fmlFmt(total), xp, topY - 3);
            });
            ctx.restore();
          }
        }]
      });
    }

    // fmlCountries.forEach removed — slide 4 uses cvMakeChart instead
    */
  </script>

  <script>
