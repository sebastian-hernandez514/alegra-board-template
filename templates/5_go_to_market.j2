    /* ── (fml functions below kept for JS parsing, body replaced above) ──
    const fmlMo = [];
    const fmlCountries = [];

    const fmlFmt = n => n >= 1000 ? (n/1000).toFixed(1).replace(/\.0$/,'') + 'K' : String(n);
    const fmlSign = n => (n > 0 ? '+' : '') + n;

    function fmlDelta(cur, prev, isPct) {
      if (prev == null) return { txt: '—', cls: 'flat' };
      if (isPct) {
        const d = Math.round((cur - prev) * 10) / 10;
        return { txt: fmlSign(d) + 'pp vs mes ant.', cls: d > 0 ? 'up' : d < 0 ? 'down' : 'flat' };
      } else {
        const d = Math.round(((cur - prev) / prev) * 100);
        return { txt: fmlSign(d) + '% vs mes ant.', cls: d > 0 ? 'up' : d < 0 ? 'down' : 'flat' };
      }
    }

    function fmlBuildKPI(id, d) {
      const n = d.cvr.length;
      const avg = Math.round(d.cvr.reduce((a,b)=>a+b,0)/n*10)/10;
      const lastCVR = d.cvr[n-1], prevCVR = d.cvr[n-2];
      const lastSU  = d.signups[n-1] ?? d.signups[n-2], prevSU = d.signups[n-2];
      const lastL   = d.logos[n-1] ?? d.logos[n-2], prevL = d.logos[n-2];
      const dCVR = fmlDelta(lastCVR, prevCVR, true);
      const dSU  = fmlDelta(lastSU, prevSU, false);
      const dL   = fmlDelta(lastL, prevL, false);
      document.getElementById(id).innerHTML = `
        <div class="fml-kpi"><div class="fml-kpi-val cvr">${lastCVR}%</div><div class="fml-kpi-lbl">CVR último mes</div><div class="fml-kpi-delta ${dCVR.cls}">${dCVR.txt}</div></div>
        <div class="fml-kpi"><div class="fml-kpi-val cvr">${avg}%</div><div class="fml-kpi-lbl">CVR promedio</div><div class="fml-kpi-delta flat">período completo</div></div>
        <div class="fml-kpi"><div class="fml-kpi-val">${fmlFmt(lastSU)}</div><div class="fml-kpi-lbl">signups último mes</div><div class="fml-kpi-delta ${dSU.cls}">${dSU.txt}</div></div>
        <div class="fml-kpi"><div class="fml-kpi-val logo">${fmlFmt(lastL)}</div><div class="fml-kpi-lbl">logos último mes</div><div class="fml-kpi-delta ${dL.cls}">${dL.txt}</div></div>
      `;
    }

    function fmlBuildCVR(id, d) {
      const n = d.cvr.length;
      const avg = Math.round(d.cvr.reduce((a,b)=>a+b,0)/n*10)/10;
      const minI = d.cvr.indexOf(Math.min(...d.cvr));
      const maxI = d.cvr.indexOf(Math.max(...d.cvr));
      const show = [...new Set([0, n-1, minI, maxI])];
      const ptR  = d.cvr.map((_,i) => show.includes(i) ? 3 : 0);
      const ptBg = d.cvr.map((_,i) => show.includes(i) ? '#1a3d6e' : 'transparent');
      new Chart(document.getElementById(id), {
        type: 'line',
        data: {
          labels: fmlMo.slice(0,n),
          datasets: [
            { data: d.cvr, borderColor: '#1a3d6e', borderWidth: 2, tension: 0.35,
              pointRadius: ptR, pointBackgroundColor: ptBg, pointBorderColor: ptBg, pointBorderWidth: 2, fill: false },
            { data: Array(n).fill(avg), borderColor: 'rgba(0,0,0,0.15)', borderWidth: 1,
              borderDash: [5,3], pointRadius: 0, fill: false }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: {
            x: { display: false },
            y: { grid: { color: fmlGridC, lineWidth: 0.5 }, border: { display: false },
                 ticks: { color: fmlTickC, font: { size: 9, family: fmlMono }, callback: v => v + '%', maxTicksLimit: 4 } }
          }
        },
        plugins: [{
          id: 'cvrLbl',
          afterDatasetsDraw(chart) {
            const { ctx, scales: { x, y } } = chart;
            ctx.save();
            ctx.font = `500 8.5px ${fmlMono}`;
            ctx.textAlign = 'center';
            ctx.fillStyle = '#1a3d6e';
            show.forEach(i => {
              const xp = x.getPixelForValue(i);
              const yp = y.getPixelForValue(d.cvr[i]);
              const off = (i === minI) ? 13 : -9;
              ctx.fillText(d.cvr[i] + '%', xp, yp + off);
            });
            ctx.restore();
          }
        }]
      });
    }

    function fmlBuildBars(id, d) {
      const n = Math.min(d.signups.length, d.logos.length);
      const logos = d.logos.slice(0, n);
      const su    = d.signups.slice(0, n);
      const nonC  = su.map((s,j) => Math.max(0, s - logos[j]));
      const midI  = Math.floor(n/2);
      const show  = [...new Set([0, midI, n-1])];
      new Chart(document.getElementById(id), {
        type: 'bar',
