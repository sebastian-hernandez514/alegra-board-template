  <!-- ============================================================
       SCRIPTS
       ============================================================ -->
  <script>
    /* ── Slide 2: New Logos charts ── */
    const months13 = {{ metrics.gtm.chart_months | tojson }};
    const tt = document.getElementById('tt');

    const coreD = {
      col: {{ metrics.gtm.new_logos_core_co | tojson }},
      mex: {{ metrics.gtm.new_logos_core_mx | tojson }},
      rd:  {{ metrics.gtm.new_logos_core_dr | tojson }},
      cr:  {{ metrics.gtm.new_logos_core_cr | tojson }}
    };
    const liteD = {
      col: {{ metrics.gtm.new_logos_lite_co | tojson }},
      mex: {{ metrics.gtm.new_logos_lite_mx | tojson }},
      rd:  {{ metrics.gtm.new_logos_lite_dr | tojson }},
      cr:  {{ metrics.gtm.new_logos_lite_cr | tojson }}
    };

    function extTT({ chart, tooltip }) {
      if (tooltip.opacity === 0) { tt.style.opacity = 0; return; }
      const r = chart.canvas.getBoundingClientRect();
      tt.style.left = (r.x + tooltip.caretX + 14) + 'px';
      tt.style.top  = (r.y + tooltip.caretY + window.scrollY - 10) + 'px';
      tt.style.opacity = 1;
      const i = tooltip.dataPoints[0].dataIndex;
      document.getElementById('tt-title').textContent = months13[i] + (i < 12 ? ' {{ config.year }}' : ' {{ config.year + 1 }}');
      const tot = tooltip.dataPoints.reduce((s, p) => s + p.raw, 0);
      document.getElementById('tt-body').innerHTML =
        tooltip.dataPoints.map(p =>
          `<div class="ttr"><span><span class="ttd" style="background:${p.dataset.backgroundColor}"></span>${p.dataset.label}</span><b>${p.raw.toLocaleString()}</b></div>`
        ).join('') +
        `<div class="ttr tttot"><span>Total</span><b>${tot.toLocaleString()}</b></div>`;
    }

    const allLogos = [...coreD.col, ...coreD.mex, ...coreD.rd, ...coreD.cr,
                      ...liteD.col, ...liteD.mex, ...liteD.rd, ...liteD.cr].filter(v => v != null);
    const sharedLogoMax = Math.ceil(Math.max(...allLogos) / 50) * 50 + 50;

    function mkChart(id, data, main, sec) {
      new Chart(document.getElementById(id), {
        type: 'bar',
        data: {
          labels: months13,
          datasets: [
            { label: 'Colombia',   data: data.col, backgroundColor: main,       stack: 's' },
            { label: 'México',     data: data.mex, backgroundColor: main + 'bb',stack: 's' },
            { label: 'Rep. Dom.',  data: data.rd,  backgroundColor: sec,        stack: 's' },
            { label: 'Costa Rica', data: data.cr,  backgroundColor: sec + 'bb', stack: 's' },
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true, position: 'bottom',
              labels: { font: { size: 9, family: 'Inter' }, color: '#999', boxWidth: 8, boxHeight: 8, padding: 8 }
            },
            tooltip: { enabled: false, external: extTT }
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { size: 9, family: 'Inter' }, color: '#999', maxRotation: 0 }, border: { display: false } },
