    function topLabelPlugin(id,labelArrays,colors){
      return { id:'lbl_'+id, afterDatasetsDraw(chart){
        const{ctx}=chart; ctx.save(); ctx.font="700 9px 'Inter',sans-serif"; ctx.textAlign='center'; ctx.textBaseline='bottom';
