<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alegra Board — Go to Market</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <link rel="stylesheet" href="../styles/base.css">
  <style>
    :root {
      --purple:   #534AB7;
      --purple-l: #AFA9EC;
      --green:    #1D9E75;
      --teal-l:   #9FE1CB;
      --coral:    #D85A30;
      --c-border: #e5e5e5;
      --c-bg2:    #f5f5f3;
      --c-dim:    #999;
      --c-muted:  #666;
    }

    /* ── Section cover ── */
    .section-cover {
      background: var(--color-navy);
      justify-content: center;
      padding: var(--slide-pad-y) var(--slide-pad-x);
    }
    .section-cover .eyebrow {
      font-size: 11px; font-weight: 600; color: var(--color-teal);
      letter-spacing: 2px; text-transform: uppercase; margin-bottom: 14px;
    }
    .section-cover .section-title {
      font-size: 42px; font-weight: 700; color: #fff;
      letter-spacing: -1.5px; line-height: 1.05; margin-bottom: 14px;
    }
    .section-cover .section-sub {
      font-size: 15px; font-weight: 400; color: rgba(255,255,255,0.40);
    }
    .section-cover .slide-num {
      position: absolute; bottom: 24px; right: var(--slide-pad-x);
      font-size: 10px; color: rgba(255,255,255,0.15);
    }

    /* ── GTM slide shell ── */
    .gtm-slide {
      width: var(--slide-width);
      height: var(--slide-height);
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow: hidden;
    }

    /* ═══════════════════════════════════════════════════
       SLIDE 2 — New Logos
    ═══════════════════════════════════════════════════ */
    .gtm-inner {
      padding: 16px 28px 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex: 1;
      min-height: 0;
    }

    .gtm-slide .dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
    .gtm-slide .dot.c { background: var(--purple); }
    .gtm-slide .dot.l { background: var(--green); }

    .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .stat-card {
      border: 0.5px solid var(--c-border); border-radius: 10px; padding: 10px 16px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .sc-left { display: flex; flex-direction: column; gap: 2px; }
    .sc-head { display: flex; align-items: center; gap: 6px; }
    .sc-seg { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; }
    .sc-seg.c { color: var(--purple); }
    .sc-seg.l { color: var(--green); }
    .sc-val { font-size: 26px; font-weight: 500; color: #111; line-height: 1; }
    .sc-deltas { display: flex; gap: 18px; }
    .sc-deltas .delta { display: flex; flex-direction: column; gap: 2px; align-items: flex-end; }
    .sc-deltas .dl { font-size: 9px; color: var(--c-dim); text-transform: uppercase; letter-spacing: .04em; }
    .sc-deltas .dv { font-size: 13px; font-weight: 600; }

    .nl-comments {
      border: 0.5px solid var(--c-border); border-radius: 10px;
      padding: 10px 14px; flex-shrink: 0; min-height: 64px;
    }
    .nl-comments-label {
      font-size: 9px; font-weight: 600; text-transform: uppercase;
      letter-spacing: .06em; color: var(--c-dim); margin-bottom: 5px;
    }
    .gtm-slide .pos { color: var(--green); }
    .gtm-slide .neg { color: var(--coral); }

    .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; flex: 1; min-height: 0; }
    .chart-card {
      border: 0.5px solid var(--c-border); border-radius: 10px; padding: 12px 14px;
      display: flex; flex-direction: column;
    }
    .cc-head { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; flex-shrink: 0; }
    .cc-label { font-size: 10px; font-weight: 600; color: var(--c-dim); text-transform: uppercase; letter-spacing: .05em; }
    .chart-wrap { position: relative; flex: 1; min-height: 0; }

    .sm-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .sm-card {
      border: 0.5px solid var(--c-border); border-radius: 10px; padding: 12px 14px;
    }
    .sm-top {
      display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 8px;
    }
    .sm-title { display: flex; align-items: center; gap: 6px; }
    .sm-lbl { font-size: 10px; font-weight: 600; color: var(--c-dim); text-transform: uppercase; letter-spacing: .05em; }
    .sm-total { font-size: 13px; font-weight: 600; color: #111; }
    .sm-var { font-size: 10px; margin-left: 6px; font-weight: 500; }

    table.sm { width: 100%; border-collapse: collapse; font-size: 11px; }
    table.sm th {
      font-size: 9px; color: var(--c-dim); font-weight: 500; padding: 0 0 5px;
      text-align: right; letter-spacing: .03em;
    }
    table.sm th:first-child { text-align: left; }
    table.sm td {
      padding: 4px 0; border-top: 0.5px solid var(--c-border);
      color: var(--c-muted); text-align: right; font-size: 11px;
    }
    table.sm td:first-child { text-align: left; color: #111; }
    table.sm tr.tot td { font-weight: 600; color: #111; border-top: 1px solid var(--c-border); }

    .insight-gtm {
      background: var(--c-bg2); border-radius: 10px;
      padding: 10px 16px; display: flex; gap: 20px;
    }
    .ins-label-col {
      flex: 0 0 auto; padding-right: 16px;
      border-right: 0.5px solid var(--c-border);
      display: flex; align-items: center;
    }
    .ins-label {
      font-size: 9px; font-weight: 600; text-transform: uppercase;
      letter-spacing: .06em; color: var(--c-dim);
    }
    .ins-item { flex: 1; display: flex; gap: 8px; align-items: flex-start; }
    .ins-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
    .ins-dot.c { background: var(--purple); }
    .ins-dot.l { background: var(--green); }
    .ins-text { font-size: 11px; color: #111; line-height: 1.5; }
    .ins-text b { font-weight: 600; }

    #tt {
      position: fixed; background: #fff; border: 0.5px solid var(--c-border);
      border-radius: 8px; padding: 8px 12px; font-size: 11px;
      pointer-events: none; opacity: 0; transition: opacity .12s; z-index: 100; min-width: 140px;
      font-family: 'Inter', sans-serif;
    }
    #tt .ttt { font-size: 9px; font-weight: 600; color: var(--c-dim); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
    #tt .ttr { display: flex; justify-content: space-between; gap: 14px; padding: 1px 0; color: var(--c-muted); }
    #tt .ttr b { font-weight: 600; color: #111; }
    #tt .ttd { width: 6px; height: 6px; border-radius: 50%; display: inline-block; margin-right: 4px; vertical-align: middle; }
    #tt .tttot { border-top: 0.5px solid var(--c-border); margin-top: 4px; padding-top: 4px; font-weight: 600; color: #111; }

    /* ═══════════════════════════════════════════════════
       SLIDE 3 — Summary Customer Acquisition
    ═══════════════════════════════════════════════════ */
    .acq-inner {
      padding: 20px 36px 20px;
      font-family: 'DM Sans', sans-serif;
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }
    /* Two-column layout: Core | Lite */
    .acq-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      flex: 1;
      min-height: 0;
    }
    .acq-col { display: flex; flex-direction: column; gap: 12px; }
    /* KPI card */
    .acq-kpi {
      background: #f8f8f6;
      border-radius: 10px;
      padding: 14px 18px;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .acq-kpi-left { display: flex; flex-direction: column; gap: 3px; }
    .acq-kpi-seg {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-family: 'DM Mono', monospace;
    }
    .acq-kpi-seg.core { color: #185FA5; }
    .acq-kpi-seg.lite { color: #1D9E75; }
    .acq-kpi-total {
      font-size: 28px;
      font-weight: 300;
      letter-spacing: -0.8px;
      color: #141413;
      line-height: 1;
    }
    .acq-kpi-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
    .acq-kpi-var {
      font-size: 10px;
      font-family: 'DM Mono', monospace;
      padding: 2px 8px;
      border-radius: 4px;
    }
    .acq-kpi-var.pos { color: #185FA5; background: rgba(24,95,165,0.09); }
    .acq-kpi-var.neg { color: #C04828; background: rgba(192,72,40,0.09); }
    .acq-kpi-mix {
      font-size: 9px;
      font-family: 'DM Mono', monospace;
      color: #a09e98;
      text-align: right;
      line-height: 1.5;
    }
    /* Chart panel */
    .acq-chart-panel {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }
    .acq-legend {
      display: flex;
      gap: 14px;
      margin-bottom: 8px;
      flex-shrink: 0;
    }
    .acq-leg {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 9px;
      color: #6b6a64;
      font-family: 'DM Mono', monospace;
    }
    .acq-leg-dot {
      width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0;
    }
    .acq-chart-box {
      position: relative;
      flex: 1;
      min-height: 0;
    }

    /* ═══════════════════════════════════════════════════
       SLIDE 4 — Acquisition Funnel
    ═══════════════════════════════════════════════════ */
    .cv-body {
      flex: 1; padding: 16px 56px 14px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .cv-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 14px; flex: 1;
    }
    .cv-card {
      background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px;
      padding: 12px 16px 10px;
      display: flex; flex-direction: column; gap: 6px;
    }
    .cv-card-header { display: flex; align-items: center; justify-content: space-between; }
    .cv-card-title {
      font-size: 11px; font-weight: 600; color: #64748b;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    .cv-legend { display: flex; gap: 12px; font-size: 10px; color: #64748b; }
    .cv-leg-item { display: flex; align-items: center; gap: 4px; }
    .cv-leg-sw { width: 9px; height: 9px; border-radius: 2px; display: inline-block; }
    .cv-chart-wrap { position: relative; flex: 1; min-height: 160px; }

    /* ═══════════════════════════════════════════════════
       SLIDE 5 — Accountant Flywheel
    ═══════════════════════════════════════════════════ */
    .fly-inner {
      padding: 20px 28px 18px;
      font-family: 'DM Sans', sans-serif;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .fly-inner .fly-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
    }
    .fly-inner .fly-title {
      font-size: 16px;
      font-weight: 500;
      color: #1a1a2e;
      letter-spacing: -0.2px;
    }
    .fly-inner .fly-date {
      font-size: 10px;
      color: #7a7870;
      margin-top: 3px;
      font-family: 'DM Mono', monospace;
    }
    .fly-inner .fly-alert {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: #fdf0eb;
      color: #c94f28;
      font-size: 10px;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 100px;
      border: 1px solid rgba(201,79,40,0.2);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .fly-inner .fly-alert-dot { width: 6px; height: 6px; background: #c94f28; border-radius: 50%; }
    .fly-inner .fly-chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    .fly-inner .fly-legend {
      display: flex;
      gap: 16px;
    }
    .fly-inner .fly-leg-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      color: #7a7870;
    }
    .fly-inner .fly-leg-line {
      width: 20px;
      height: 2.5px;
      border-radius: 2px;
    }
    .fly-inner .fly-leg-area {
      width: 16px;
      height: 9px;
      border-radius: 3px;
      opacity: 0.35;
    }
    .fly-inner .fly-gap-target {
      font-size: 9px;
      color: #1d9e75;
      background: rgba(29,158,117,0.08);
      border: 1px solid rgba(29,158,117,0.2);
      padding: 2px 8px;
      border-radius: 100px;
      font-weight: 500;
    }
    .fly-inner .fly-chart-wrap {
      background: #faf9f7;
      border: 1px solid rgba(0,0,0,0.09);
      border-radius: 10px;
      padding: 12px 14px 8px;
      overflow: hidden;
    }
    .fly-inner .fly-chart-label {
      font-size: 9px;
      font-weight: 500;
      color: #7a7870;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 8px;
    }
    .fly-inner .fly-insight-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 9px;
      margin-top: 4px;
    }
    .fly-inner .fly-icard {
      border-radius: 10px;
      padding: 10px 13px;
      border-left: 3px solid transparent;
    }
    .fly-inner .fly-icard.insight { background: #eef6ff; border-color: #1a6dcc; }
    .fly-inner .fly-icard.risk    { background: #fdf0eb; border-color: #c94f28; }
    .fly-inner .fly-icard.action  { background: #edf7f3; border-color: #1d9e75; }
    .fly-inner .fly-icard-tag {
      font-size: 9px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 4px;
    }
    .fly-inner .fly-icard.insight .fly-icard-tag { color: #1a6dcc; }
    .fly-inner .fly-icard.risk    .fly-icard-tag { color: #c94f28; }
    .fly-inner .fly-icard.action  .fly-icard-tag { color: #1d9e75; }
    .fly-inner .fly-icard-text {
      font-size: 10.5px;
      color: #1a1a2e;
      line-height: 1.55;
    }
    .fly-inner .fly-icard-text strong { font-weight: 500; }

    /* ═══════════════════════════════════════════════════
       SLIDE 6 — Placeholder
    ═══════════════════════════════════════════════════ */
    .placeholder-inner {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      padding: 40px;
      min-height: 380px;
    }
    .placeholder-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #94a3b8;
    }
    .placeholder-note {
      font-size: 12px;
      color: #cbd5e1;
      text-align: center;
      max-width: 340px;
    }

    /* ── Contadores index-3 (1/3) ── */
    .cp-header {
      background: #0f172b; height: 40px; flex: 0 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px; color: #ffffff;
    }
    .cp-header .title { font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700; }
    .cp-header .sub { font-size: 10.5px; color: #94a3b8; font-weight: 500; }
    .cp-pill { background: #14b8a6; color: #0f172b; font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 6px; }
    .cp-insight { flex: 0 0 30px; background: #f0fdfa; border-left: 3px solid #14b8a6; display: flex; align-items: center; padding: 0 16px; font-size: 11px; color: #334155; font-weight: 500; }
    .cp-insight strong { color: #0f172b; font-weight: 700; margin-right: 4px; }
    .cp-body { flex: 1 1 auto; display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: 1fr 1fr; gap: 8px; padding: 10px; min-height: 0; }
    .cp-card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 6px; padding: 8px 10px 6px; display: flex; flex-direction: column; min-height: 0; }
    .cp-card-title { font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700; color: #0f172b; line-height: 1.2; }
    .cp-card-sub { font-size: 9px; color: #64748b; margin-top: 2px; font-weight: 500; }
    .cp-kpi { display: flex; align-items: baseline; gap: 6px; margin-top: 3px; }
    .cp-kpi .val { font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 700; color: #0f172b; }
    .cp-kpi .delta { font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 99px; }
    .cp-kpi .delta.pos { background: #dcfce7; color: #16a34a; }
    .cp-kpi .delta.neg { background: #ffedd5; color: #C2410C; }
    .cp-kpi .delta.neutral { background: #f1f5f9; color: #64748b; }
    .cp-chart-wrap { flex: 1 1 auto; position: relative; min-height: 0; margin-top: 4px; }
    .cp-legend { display: flex; gap: 8px; font-size: 9px; color: #64748b; margin-top: 2px; }
    .cp-legend .sw { display: inline-block; width: 8px; height: 8px; border-radius: 2px; margin-right: 3px; vertical-align: middle; }
    .cp-footer { flex: 0 0 22px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; background: #f8fafc; border-top: 1px solid #e2e8f0; font-size: 9.5px; color: #64748b; }

    /* ── Contadores index-1 (2/3) ── */
    .cp2-header { background: #0f172b; height: 40px; flex: 0 0 40px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; color: #ffffff; }
    .cp2-header .title { font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700; }
    .cp2-header .sub { font-size: 10.5px; color: #94a3b8; font-weight: 500; }
    .cp2-pill { background: #14b8a6; color: #0f172b; font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 6px; }
    .cp2-insight { flex: 0 0 30px; background: #f0fdfa; border-left: 3px solid #14b8a6; display: flex; align-items: center; padding: 0 16px; font-size: 11px; color: #334155; font-weight: 500; }
    .cp2-insight strong { color: #0f172b; font-weight: 700; margin-right: 4px; }
    .cp2-body { flex: 1 1 auto; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1.2fr 1fr; gap: 8px; padding: 10px; min-height: 0; }
    .cp2-body .wide { grid-column: 1 / span 2; }
    .cp2-card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 6px; padding: 8px 10px 6px; display: flex; flex-direction: column; min-height: 0; }
    .cp2-card-title { font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700; color: #0f172b; line-height: 1.2; }
    .cp2-card-sub { font-size: 9px; color: #64748b; margin-top: 2px; font-weight: 500; }
    .cp2-chart-wrap { flex: 1 1 auto; position: relative; min-height: 0; margin-top: 4px; }
    .cp2-legend { display: flex; gap: 10px; font-size: 9px; color: #64748b; margin-top: 2px; }
    .cp2-legend .sw { display: inline-block; width: 8px; height: 8px; border-radius: 2px; margin-right: 3px; vertical-align: middle; }
    .cp2-footer { flex: 0 0 22px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; background: #f8fafc; border-top: 1px solid #e2e8f0; font-size: 9.5px; color: #64748b; }

    /* ── Contadores index-2 (3/3) ── */
    .cp3-header { background: #0f172b; height: 40px; flex: 0 0 40px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; color: #ffffff; }
    .cp3-header .title { font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 700; }
    .cp3-header .sub { font-size: 10.5px; color: #94a3b8; font-weight: 500; }
    .cp3-pill { background: #14b8a6; color: #0f172b; font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 6px; }
    .cp3-insight { flex: 0 0 30px; background: #f0fdfa; border-left: 3px solid #14b8a6; display: flex; align-items: center; padding: 0 16px; font-size: 11px; color: #334155; font-weight: 500; }
    .cp3-insight strong { color: #0f172b; font-weight: 700; margin-right: 4px; }
    .cp3-body { flex: 1 1 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 14px 18px; min-height: 0; }
    .cp3-card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 12px 14px; display: flex; flex-direction: column; min-height: 0; }
    .cp3-card-title { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 700; color: #0f172b; line-height: 1.2; }
    .cp3-kpi-row { display: flex; gap: 18px; margin: 6px 0 8px; }
    .cp3-kpi { display: flex; flex-direction: column; }
    .cp3-kpi .lbl { font-size: 9px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: .4px; }
    .cp3-kpi .val { font-family: 'DM Sans', sans-serif; font-size: 20px; font-weight: 700; color: #0f172b; line-height: 1; }
    .cp3-kpi .val.teal { color: #1A7E7F; }
    .cp3-kpi .val.violet { color: #6366F1; }
    .cp3-kpi .delta { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 99px; align-self: flex-start; margin-top: 4px; }
    .cp3-kpi .delta.pos { background: #dcfce7; color: #16a34a; }
    .cp3-chart-wrap { flex: 1 1 auto; position: relative; min-height: 0; }
    .cp3-legend { display: flex; gap: 12px; font-size: 10px; color: #64748b; margin-top: 6px; }
    .cp3-legend .sw { display: inline-block; width: 9px; height: 9px; border-radius: 2px; margin-right: 4px; vertical-align: middle; }
    .cp3-footer { flex: 0 0 22px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; background: #f8fafc; border-top: 1px solid #e2e8f0; font-size: 9.5px; color: #64748b; }
  </style>
</head>
