<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alegra Board — Appendix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../styles/base.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <style>
    .section-cover {
      background: var(--color-navy);
      justify-content: center;
      padding: var(--slide-pad-y) var(--slide-pad-x);
    }
    .section-cover .eyebrow {
      font-size: 11px; font-weight: 600; color: var(--color-teal);
      letter-spacing: 2px; text-transform: uppercase; margin-bottom: 14px;
    }
    .section-cover .section-title {
      font-size: 42px; font-weight: 700; color: #ffffff;
      letter-spacing: -1.5px; line-height: 1.05; margin-bottom: 14px;
    }
    .section-cover .section-sub {
      font-size: 15px; font-weight: 400; color: rgba(255,255,255,0.40);
    }
    .section-cover .slide-num {
      position: absolute; bottom: 24px; right: var(--slide-pad-x);
      font-size: 10px; color: rgba(255,255,255,0.15);
    }

    /* ── Net ARR Expansion ── */
    .nw-header {
      background: #0f172b;
      height: 44px;
      flex: 0 0 44px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px;
      color: #ffffff;
    }
    .nw-header .title {
      font-family: 'DM Sans', sans-serif;
      font-size: 16px; font-weight: 700; letter-spacing: .1px;
    }
    .nw-pill {
      background: #14b8a6; color: #0f172b;
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; font-weight: 700;
      padding: 4px 14px; border-radius: 6px; letter-spacing: .3px;
    }
    .nw-subhead {
      flex: 0 0 28px; display: flex; align-items: center;
      padding: 0 20px;
      background: #f8fafc; border-bottom: 1px solid #e2e8f0;
      font-size: 11px; color: #475569; font-weight: 500;
    }
    .nw-subhead strong { color: #0f172b; font-weight: 600; margin-right: 6px; }
    .nw-subhead .pos { color: #16a34a; font-weight: 700; margin-left: 2px; }
    .nw-body {
      flex: 1 1 auto; display: flex; flex-direction: column;
      padding: 8px 18px 0; gap: 4px; min-height: 0;
    }
    .nw-panel { flex: 1 1 0; display: flex; flex-direction: column; min-height: 0; }
    .nw-panel-head { display: flex; align-items: baseline; gap: 10px; padding: 2px; }
    .nw-panel-title { font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 700; color: #0f172b; }
    .nw-panel-sep { color: #cbd5e1; font-size: 10px; }
    .nw-panel-meta { font-size: 10.5px; color: #475569; font-weight: 500; }
    .nw-panel-meta .val { font-weight: 700; }
    .nw-panel-meta .pos { color: #16a34a; }
    .nw-panel-meta .neg { color: #C2410C; }
    .nw-panel-note {
      font-size: 9.5px; color: #64748b; font-style: italic;
      margin-left: auto; font-weight: 500;
    }
    .nw-panel-note .mk { color: #14b8a6; font-style: normal; font-weight: 700; }
    .nw-chart-wrap { flex: 1 1 auto; position: relative; min-height: 0; }
    .nw-footer {
      flex: 0 0 22px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px;
      background: #f8fafc; border-top: 1px solid #e2e8f0;
      font-size: 9.5px; color: #64748b;
    }

    /* ── Cohort slides ── */
    .country-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 12px 36px;
      flex: 1; min-height: 0;
    }
    .country-card {
      display: flex; flex-direction: column; min-height: 0;
    }
    .country-card .c-head {
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 6px;
    }
    .country-card .c-title {
      font-size: 13px; font-weight: 700; color: var(--color-navy);
      letter-spacing: 1.2px; text-transform: uppercase;
    }
    .country-card .chart-wrap { position: relative; flex: 1; min-height: 0; }

    .legend-strip {
      display: flex; gap: 28px; justify-content: center; align-items: center;
      padding: 0 0 4px;
      font-size: 11px; color: var(--color-text-secondary); font-weight: 500;
      flex-shrink: 0;
    }
    .legend-strip .li { display: inline-flex; align-items: center; gap: 8px; letter-spacing: 0.3px; }
    .legend-strip .sw {
      width: 24px; height: 2.5px; border-radius: 1px; background: var(--color-gold);
    }
    .legend-strip .sw.dashed {
      background: transparent;
      border-top: 2px dashed #94a3b8;
      height: 0;
    }

    .delta-chip {
      display: inline-flex; align-items: center; padding: 1px 7px;
      border-radius: 99px; font-size: 9.5px; font-weight: 700;
      letter-spacing: 0.2px;
      font-variant-numeric: tabular-nums;
    }
    .delta-chip.up   { background: #dcfce7; color: #16a34a; }
    .delta-chip.down { background: #ffedd5; color: #C2410C; }
    .delta-chip.flat { background: #f1f5f9; color: #64748b; }

    .insight-box {
      background: #f0fdfa;
      border-left: 3px solid var(--color-teal);
      border-radius: 0 6px 6px 0;
      padding: 10px 16px;
      font-size: 11.5px;
      color: var(--color-text-secondary);
      line-height: 1.55;
      flex-shrink: 0;
    }
    .insight-box strong { color: var(--color-text-primary); font-weight: 600; }
    .insight-box .so-what {
      display: inline-block;
      font-size: 9.5px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--color-teal);
      margin-right: 8px;
    }
  </style>
</head>
<body>

  <!-- ============================================================
       SLIDE 1 — Section Cover
       ============================================================ -->
  <div class="slide section-cover">
    <div class="eyebrow">Section 08</div>
    <div class="section-title">Appendix</div>
    <div class="section-sub">{{ config.quarter_label }}</div>
    <div class="slide-num">1</div>
  </div>

  <div class="slide-divider">↓</div>

  <!-- ============================================================
       SLIDE 2 — Net ARR Expansion
       ============================================================ -->
  <div class="slide">
    <div class="nw-header">
      <span class="title">Net ARR Expansion — Breakdown by Component</span>
      <span class="nw-pill">1Q26</span>
    </div>

    <div class="nw-subhead">
      <strong>1Q26 Net ARR Expansion:</strong><span class="pos">+$403K</span>
    </div>

    <div class="nw-body">
      <div class="nw-panel">
        <div class="nw-panel-head">
          <span class="nw-panel-title">Others &amp; Pricing</span>
          <span class="nw-panel-sep">·</span>
          <span class="nw-panel-meta">1Q26: <span class="val pos">+$704K</span></span>
          <span class="nw-panel-note"><span class="mk">★</span> = price increase quarter &nbsp;·&nbsp; Includes discount expirations &amp; other MRR movements not driven by cross- or upselling</span>
        </div>
        <div class="nw-chart-wrap"><canvas id="chartOthers"></canvas></div>
      </div>

      <div class="nw-panel">
        <div class="nw-panel-head">
          <span class="nw-panel-title">Upselling</span>
          <span class="nw-panel-sep">·</span>
          <span class="nw-panel-meta">1Q26: <span class="val neg">($268K)</span></span>
          <span class="nw-panel-note">Plan tier changes within the same product — typically negative in Q1 as seasonal year-end upgrades (Q4) normalize in the following quarter</span>
        </div>
        <div class="nw-chart-wrap"><canvas id="chartUpsell"></canvas></div>
      </div>

      <div class="nw-panel">
        <div class="nw-panel-head">
          <span class="nw-panel-title">Crosselling</span>
          <span class="nw-panel-sep">·</span>
          <span class="nw-panel-meta">1Q26: <span class="val neg">($34K)</span></span>
          <span class="nw-panel-note">Add-on product additions or removals by existing paying customers</span>
        </div>
        <div class="nw-chart-wrap"><canvas id="chartCross"></canvas></div>
      </div>
    </div>

    <div class="nw-footer">
      <span>Source: Finance · Mar 2026</span>
      <span>Alegra · Confidential &nbsp; 2</span>
    </div>
  </div>

  <div class="slide-divider">↓</div>

  <!-- ============================================================
       SLIDE 3 — Core Cohorts
       ============================================================ -->
  <div class="slide">
    <div class="slide-header">
      <span class="title" style="font-size: 15px;">Core cohorts · 2026 starts above 2025 in COL, MEX, CRI · DOM is the early lag (−3.3 pp at M2)</span>
      <span class="period">{{ config.quarter_label }}</span>
    </div>
    <div class="slide-body" style="gap: 10px; padding-top: 14px; padding-bottom: 6px; min-height: 0;">

      <div class="legend-strip">
        <span class="li"><span class="sw"></span> 2026 cohorts</span>
        <span class="li"><span class="sw dashed"></span> 2025 cohorts</span>
      </div>

      <div class="country-grid">
        <div class="country-card">
          <div class="c-head"><span class="c-title">COL</span></div>
          <div class="chart-wrap"><canvas id="ch_COL_Core"></canvas></div>
        </div>
        <div class="country-card">
          <div class="c-head"><span class="c-title">DOM</span></div>
          <div class="chart-wrap"><canvas id="ch_DOM_Core"></canvas></div>
        </div>
        <div class="country-card">
          <div class="c-head"><span class="c-title">MEX</span></div>
          <div class="chart-wrap"><canvas id="ch_MEX_Core"></canvas></div>
        </div>
        <div class="country-card">
          <div class="c-head"><span class="c-title">CRI</span></div>
          <div class="chart-wrap"><canvas id="ch_CRI_Core"></canvas></div>
        </div>
      </div>

      <div class="insight-box">
        <span class="so-what">So what</span>
        At M2 (the overlap point), <strong>CRI Core leads +7.7 pp vs 2025</strong> and MEX +3.5 pp · COL +1.3 pp.
        DOM is the only Core market under baseline (<strong>−3.3 pp at M2</strong>) — worth a deeper look before the 2026-Q1 cohort matures.
      </div>
    </div>
    <div class="slide-footer">
      <span class="footer-brand">Alegra · Confidential</span>
      <span class="footer-page">3</span>
    </div>
  </div>

  <div class="slide-divider">↓</div>

  <!-- ============================================================
       SLIDE 4 — Lite Cohorts
       ============================================================ -->
  <div class="slide">
    <div class="slide-header">
      <span class="title" style="font-size: 15px;">Lite cohorts · uniformly tougher floor (~70% at M2) · DOM 2026 is the positive surprise (+3.9 pp)</span>
      <span class="period">{{ config.quarter_label }}</span>
    </div>
    <div class="slide-body" style="gap: 10px; padding-top: 14px; padding-bottom: 6px; min-height: 0;">

      <div class="legend-strip">
        <span class="li"><span class="sw"></span> 2026 cohorts</span>
        <span class="li"><span class="sw dashed"></span> 2025 cohorts</span>
      </div>

      <div class="country-grid">
        <div class="country-card">
          <div class="c-head"><span class="c-title">COL</span></div>
          <div class="chart-wrap"><canvas id="ch_COL_Lite"></canvas></div>
        </div>
        <div class="country-card">
          <div class="c-head"><span class="c-title">DOM</span></div>
          <div class="chart-wrap"><canvas id="ch_DOM_Lite"></canvas></div>
        </div>
        <div class="country-card">
          <div class="c-head"><span class="c-title">MEX</span></div>
          <div class="chart-wrap"><canvas id="ch_MEX_Lite"></canvas></div>
        </div>
        <div class="country-card">
          <div class="c-head"><span class="c-title">CRI</span></div>
          <div class="chart-wrap"><canvas id="ch_CRI_Lite"></canvas></div>
        </div>
      </div>

      <div class="insight-box">
        <span class="so-what">So what</span>
        Lite starts steeper everywhere — <strong>~15-25 pp below Core by M2</strong>. 2026 vs 2025 at M2: DOM <strong>+3.9 pp</strong> · CRI +1.0 · COL +1.0 · MEX <strong>−2.4 pp</strong> (watchlist).
        The 2025 baseline already shows M12+ settling around <strong>40-50% retention</strong>, the Lite structural floor.
      </div>
    </div>
    <div class="slide-footer">
      <span class="footer-brand">Alegra · Confidential</span>
      <span class="footer-page">4</span>
    </div>
  </div>

  <script>
    (function(){
      Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
      Chart.defaults.font.size = 9;
      Chart.defaults.color = '#64748b';

      const quarters = ['1Q24','2Q24','3Q24','4Q24','1Q25','2Q25','3Q25','4Q25','1Q26'];
      const fmtK = v => {
        if (v === 0) return '$0';
        const abs = Math.abs(v).toLocaleString('en-US');
        return v < 0 ? '(\$' + abs + 'K)' : '\$' + abs + 'K';
      };
      const others = [1169, 366, 1734, 461, 2838, 552, 568, 790, 704];
      const othersStar = [false, false, true, false, true, false, false, false, false];
      const upsell = [-11, 354, 368, 635, -31, 174, 178, 751, -268];
      const cross  = [-30, 70, -1, 6, -60, -68, -47, -32, -34];

      const mkOptions = (min, max, stepSize) => ({
        responsive: true, maintainAspectRatio: false, animation: false,
        layout: { padding: { top: 18, right: 20, left: 6, bottom: 2 } },
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: {
          x: {
            grid: { display: false }, border: { color: '#e2e8f0' },
            ticks: { color: '#64748b', font: { family: 'DM Sans', size: 9.5, weight: '500' } }
          },
          y: {
            min, max,
            grid: { color: 'rgba(15,23,43,.06)' }, border: { display: false },
            afterFit: (scale) => { scale.width = 38; },
            ticks: {
              color: '#94a3b8', font: { family: 'DM Mono', size: 8.5 },
              stepSize, autoSkip: false, maxTicksLimit: 6, padding: 4,
              callback: v => {
                if (v === 0) return '0';
                const abs = Math.abs(v).toLocaleString('en-US');
                return v < 0 ? '\u2212' + abs : abs;
              }
            }
          }
        }
      });

      const makeLabelPlugin = (id, color, values, opts = {}) => ({
        id,
        afterDatasetsDraw(chart) {
          const {ctx} = chart;
          const meta = chart.getDatasetMeta(0);
          ctx.save();
          ctx.font = "700 9.5px 'Inter', sans-serif";
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          meta.data.forEach((pt, i) => {
            if (!pt) return;
            const v = values[i];
            const label = fmtK(v);
            const dy = v >= 0 ? -11 : 11;
            ctx.fillStyle = color;
            ctx.fillText(label, pt.x, pt.y + dy);
            if (opts.stars && opts.stars[i]) {
              ctx.fillStyle = '#14b8a6';
              ctx.font = "700 11px 'Inter', sans-serif";
              ctx.fillText('★', pt.x + ctx.measureText(label).width/2 + 8, pt.y + dy);
              ctx.font = "700 9.5px 'Inter', sans-serif";
            }
          });
          ctx.restore();
        }
      });

      const mkDataset = (data, color) => ({
        data, borderColor: color, backgroundColor: color,
        pointBackgroundColor: color, pointBorderColor: color,
        pointRadius: 3.5, borderWidth: 2, tension: 0
      });

      new Chart(document.getElementById('chartOthers'), {
        type: 'line', data: { labels: quarters, datasets: [mkDataset(others, '#14b8a6')] },
        options: mkOptions(0, 3000, 1000),
        plugins: [makeLabelPlugin('lblOthers', '#0f172b', others, { stars: othersStar })]
      });
      new Chart(document.getElementById('chartUpsell'), {
        type: 'line', data: { labels: quarters, datasets: [mkDataset(upsell, '#6366F1')] },
        options: mkOptions(-500, 1000, 500),
        plugins: [makeLabelPlugin('lblUpsell', '#0f172b', upsell)]
      });
      new Chart(document.getElementById('chartCross'), {
        type: 'line', data: { labels: quarters, datasets: [mkDataset(cross, '#E87722')] },
        options: mkOptions(-110, 110, 50),
        plugins: [makeLabelPlugin('lblCross', '#0f172b', cross)]
      });
    })();
  </script>

  <script>
    (function(){
      Chart.defaults.font.family = "'Inter', sans-serif";

      const DATA = {
        COL_Core_2025: [100.0, 87.11, 80.8, 76.73, 74.93, 72.86, 71.92, 69.3, 67.93, 66.34, 66.04, 65.45, 60.53, 57.96, 56.03],
        COL_Core_2026: [100.0, 88.57, 82.07, null, null, null, null, null, null, null, null, null, null, null, null],
        COL_Lite_2025: [100.0, 83.31, 75.98, 70.31, 67.28, 64.47, 62.42, 60.4, 59.27, 57.72, 56.68, 55.39, 51.77, 50.38, 47.8],
        COL_Lite_2026: [100.0, 85.8, 76.96, null, null, null, null, null, null, null, null, null, null, null, null],
        DOM_Core_2025: [100.0, 90.12, 82.72, 76.7, 73.75, 71.38, 69.42, 68.65, 63.71, 61.56, 61.23, 59.53, 56.71, 51.06, 48.28],
        DOM_Core_2026: [100.0, 91.53, 79.41, null, null, null, null, null, null, null, null, null, null, null, null],
        DOM_Lite_2025: [100.0, 84.69, 74.42, 66.81, 61.99, 56.45, 53.43, 49.4, 47.58, 47.81, 44.57, 44.93, 45.33, 45.0, 40.58],
        DOM_Lite_2026: [100.0, 87.8, 78.36, null, null, null, null, null, null, null, null, null, null, null, null],
        MEX_Core_2025: [100.0, 87.15, 80.21, 75.46, 72.02, 69.35, 67.35, 63.64, 60.34, 58.77, 59.89, 57.48, 57.87, 54.23, 54.88],
        MEX_Core_2026: [100.0, 89.71, 83.75, null, null, null, null, null, null, null, null, null, null, null, null],
        MEX_Lite_2025: [100.0, 78.41, 72.33, 65.53, 62.85, 61.44, 59.1, 57.03, 54.59, 53.12, 51.35, 50.9, 45.22, 44.35, 42.34],
        MEX_Lite_2026: [100.0, 80.57, 69.92, null, null, null, null, null, null, null, null, null, null, null, null],
        CRI_Core_2025: [100.0, 83.61, 77.26, 75.25, 71.12, 71.26, 68.33, 68.72, 65.69, 64.41, 63.33, 66.15, 63.64, 68.75, 65.22],
        CRI_Core_2026: [100.0, 92.31, 85.0, null, null, null, null, null, null, null, null, null, null, null, null],
        CRI_Lite_2025: [100.0, 81.09, 70.15, 65.67, 60.28, 58.64, 56.52, 52.33, 52.53, 51.85, 52.02, 47.85, 40.62, 42.39, 42.59],
        CRI_Lite_2026: [100.0, 81.82, 71.15, null, null, null, null, null, null, null, null, null, null, null, null],
      };

      const LABELS = Array.from({length: 15}, (_, i) => String(i));
      const COLOR_2026 = '#c59b2d';
      const COLOR_2025 = '#94a3b8';

      function makeChart(canvasId, key) {
        new Chart(document.getElementById(canvasId), {
          type: 'line',
          data: {
            labels: LABELS,
            datasets: [
              {
                label: '2025', data: DATA[key + '_2025'],
                borderColor: COLOR_2025, borderWidth: 1.8,
                borderDash: [5, 4], pointRadius: 0, pointHoverRadius: 4,
                pointBackgroundColor: COLOR_2025, pointBorderColor: '#ffffff',
                tension: 0.30, fill: false, spanGaps: false
              },
              {
                label: '2026', data: DATA[key + '_2026'],
                borderColor: COLOR_2026, backgroundColor: 'rgba(197,155,45,0.10)',
                borderWidth: 2.5, pointRadius: 0, pointHoverRadius: 5,
                pointBackgroundColor: COLOR_2026, pointBorderColor: '#ffffff',
                pointBorderWidth: 1.5, tension: 0.30, fill: true, spanGaps: false
              }
            ]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            layout: { padding: { top: 4, right: 4, bottom: 0, left: 0 } },
            interaction: { mode: 'index', intersect: false, axis: 'x' },
            plugins: {
              legend: { display: false },
              tooltip: {
                enabled: true, backgroundColor: '#0f172b', padding: 10,
                titleFont: { size: 11, weight: '600' }, titleColor: '#ffffff',
                bodyFont: { size: 11 }, bodyColor: '#ffffff',
                displayColors: true, boxPadding: 4, cornerRadius: 6,
                borderColor: 'rgba(255,255,255,0.1)', borderWidth: 1,
                callbacks: {
                  title: items => 'Month ' + items[0].label,
                  label: ctx => ctx.raw == null ? null : `  ${ctx.dataset.label}: ${ctx.raw.toFixed(1)}%`
                }
              }
            },
            scales: {
              y: {
                min: 0, max: 100,
                grid: { color: '#f1f5f9', drawBorder: false },
                border: { display: false },
                ticks: { callback: v => v + '%', font: { size: 9.5 }, color: '#94a3b8', stepSize: 20, padding: 4 }
              },
              x: {
                grid: { display: false },
                border: { display: false },
                ticks: {
                  font: { size: 9.5 }, color: '#94a3b8', maxRotation: 0,
                  autoSkip: false, padding: 2,
                  callback: function(v, i) { return i % 2 === 0 ? this.getLabelForValue(v) : ''; }
                }
              }
            }
          }
        });
      }

      ['COL_Core','DOM_Core','MEX_Core','CRI_Core',
       'COL_Lite','DOM_Lite','MEX_Lite','CRI_Lite'].forEach(k =>
         makeChart('ch_' + k, k)
       );
    })();
  </script>

</body>
</html>
