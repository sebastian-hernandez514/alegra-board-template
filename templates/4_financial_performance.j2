<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alegra Board — Financial Performance</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <link rel="stylesheet" href="../styles/base.css">
  <style>

    /* ── CSS variables (finance slides) ── */
    :root {
      --navy: #0f172b; --teal: #14b8a6; --teal-light: #f0fdfa;
      --bg: #ffffff; --surface: #f8fafc; --border: #e2e8f0;
      --positive: #185FA5; --negative: #E87722; --neutral: #64748b;
      --text-primary: #0f172b; --text-secondary: #64748b;
    }

    /* ── Section cover ── */
    .section-cover {
      background: var(--color-navy);
      justify-content: center;
      padding: var(--slide-pad-y) var(--slide-pad-x);
    }
    .section-cover .eyebrow {
      font-size: 11px; font-weight: 600; color: var(--color-teal);
      letter-spacing: 2px; text-transform: uppercase; margin-bottom: 14px;
    }
    .section-cover .section-title {
      font-size: 42px; font-weight: 700; color: #ffffff;
      letter-spacing: -1.5px; line-height: 1.05; margin-bottom: 14px;
    }
    .section-cover .section-sub {
      font-size: 15px; font-weight: 400; color: rgba(255,255,255,0.40);
    }
    .section-cover .slide-num {
      position: absolute; bottom: 24px; right: var(--slide-pad-x);
      font-size: 10px; color: rgba(255,255,255,0.15);
    }

    /* ── Slide shell ── */
    .fp-slide {
      width: var(--slide-width);
      height: var(--slide-height);
      overflow: hidden;
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }

    /* ── Slide header sub-elements ── */
    .slide-header-title  { font-size: 17px; font-weight: 600; color: #fff; font-family: 'DM Sans'; line-height: 1.3; }
    .slide-header-period { font-size: 13px; font-weight: 500; color: var(--teal); white-space: nowrap; }
    .slide-header-num    { font-size: 11px; font-weight: 500; color: rgba(255,255,255,.35); font-family: 'DM Mono'; white-space: nowrap; }

    /* ── Body / footer ── */
    .fp-body   { padding: 14px 56px 10px; flex: 1; display: flex; flex-direction: column; gap: 8px; overflow: hidden; }
    .fp-footer { padding: 8px 56px 12px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; background: var(--surface); border-top: 1px solid var(--border); }
    .fp-footer .footer-brand  { font-size: 10px; font-weight: 500; color: #94a3b8; }
    .fp-footer .footer-source { font-size: 9px; font-style: italic; color: var(--neutral); }
    .fp-footer .footer-page   { font-size: 10px; font-weight: 500; color: var(--neutral); }

    /* ── Insight boxes ── */
    .fp-insight       { border-radius: 8px; padding: 7px 14px; font-size: 11.5px; font-weight: 500; flex-shrink: 0; line-height: 1.45; font-family: 'DM Sans', sans-serif; }
    .fp-insight-blue  { background: #0e3d5c; color: #fff; }
    .fp-insight-green { background: #0b4d3a; color: #fff; }
    .fp-insight-teal  { background: var(--teal-light); border-left: 3px solid var(--teal); color: var(--text-secondary); border-radius: 0 6px 6px 0; }
    .fp-insight-teal b { color: var(--text-primary); }

    /* ── Finance data table — estilo ARR Walk ── */
    .fp-table                   { width: 100%; border-collapse: collapse; font-size: 10.5px; }
    .fp-table thead tr          { border-bottom: 1.5px solid #e2e8f0; }
    .fp-table thead th          { padding: 3px 7px 5px; text-align: right; font-size: 9.5px; font-weight: 700; color: #94a3b8; white-space: nowrap; letter-spacing: .5px; text-transform: uppercase; }
    .fp-table thead th:first-child { text-align: left; padding-left: 4px; color: #0f172b; }
    .fp-table thead th.tha      { color: #1e293b; }
    .fp-table tbody td          { border-bottom: 1px solid #f1f5f9; }
    .fp-table tbody tr:hover    { background: #fafafa; }
    .fp-row-section td          { padding: 5px 7px 3px; font-weight: 700; font-size: 8.5px; background: #f8fafc;
                                   text-transform: uppercase; letter-spacing: 1.4px; color: #0f172b !important;
                                   border-top: 1.5px solid #e2e8f0 !important; border-bottom: none !important; }
    .fp-row-section td:first-child { padding-left: 4px; color: #30b8b7 !important; }
    .fp-row-calc td             { padding: 0 7px; height: 23px; font-weight: 700; background: var(--bg);
                                   font-family: 'DM Mono'; font-size: 11px; color: #1e293b;
                                   border-bottom: 1.5px solid #e2e8f0 !important; vertical-align: middle; }
    .fp-row-calc td:first-child { padding-left: 4px; font-family: 'DM Sans'; color: #0f172b; }
    .fp-row-sub td              { padding: 0 7px; height: 21px; background: var(--bg);
                                   font-family: 'DM Mono'; font-size: 10.5px; color: #475569; vertical-align: middle; }
    .fp-row-sub td:first-child  { padding-left: 20px; font-family: 'DM Sans'; color: #475569; }
    .fp-row-margin td           { height: 17px; padding: 0 7px; font-size: 9.5px; color: #94a3b8;
                                   font-style: italic; background: var(--bg); vertical-align: middle;
                                   border-bottom: 1px solid transparent !important; }
    .fp-row-margin td:first-child { padding-left: 20px; font-size: 10px; }
    .fp-row-total td            { padding: 5px 7px; font-weight: 700; background: #0b1e3a; color: #fff;
                                   font-family: 'DM Mono'; font-size: 10.5px; }
    .fp-row-total td:first-child { padding-left: 4px; font-family: 'DM Sans'; }
    .fp-row-total-margin td     { padding: 1.5px 7px; font-size: 9.5px; font-style: italic;
                                   background: #0b1e3a; color: #475569;
                                   border-bottom: 1px solid transparent !important; }
    .fp-row-total-margin td:first-child { padding-left: 20px; }
    .fp-tn { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; font-family: 'DM Mono'; }
    .fp-tm { text-align: right; color: #94a3b8; font-variant-numeric: tabular-nums; white-space: nowrap; font-family: 'DM Mono'; font-size: 9.5px; }
    .fp-tv { text-align: right; white-space: nowrap; }

    /* ── Delta pills ── */
    .db   { display: inline-flex; align-items: center; gap: 2px; font-size: 10px; font-weight: 600; font-family: 'DM Mono'; padding: 1px 5px; border-radius: 4px; }
    .db.p { color: var(--positive); background: #dbeafe; }
    .db.n { color: var(--negative); background: #fff7ed; }
    .db.z { color: var(--neutral);  background: var(--surface); }

    /* ── Chart wrapper ── */
    .fp-chart-wrap        { position: relative; width: 100%; }
    .fp-chart-wrap canvas { display: block; width: 100% !important; }

    /* ── Section label ── */
    .fp-sec-label { font-size: 9.5px; font-weight: 700; color: var(--teal); text-transform: uppercase; letter-spacing: 1.5px; }

    /* ── Cash flow table ── */
    .cf-table                       { width: 100%; border-collapse: collapse; font-size: 10.5px; }
    /* ── Cash flow table — estilo ARR Walk ── */
    .cf-table                       { width: 100%; border-collapse: collapse; font-size: 10px; }
    .cf-table thead tr              { border-bottom: 1.5px solid #e2e8f0; }
    .cf-table thead th              { color: #94a3b8; padding: 3px 6px 5px; text-align: right; font-size: 9px; font-weight: 700; text-transform: uppercase; white-space: nowrap; letter-spacing: .4px; }
    .cf-table thead th:first-child  { text-align: left; padding-left: 4px; color: #0f172b; }
    .cf-table thead th.tha          { color: #1e293b; }
    .cf-table td                    { padding: 0 6px; height: 20px; text-align: right; font-family: 'DM Mono'; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .cf-table td:first-child        { text-align: left; padding-left: 4px; font-family: 'DM Sans'; white-space: nowrap; }
    .cf-table tr.tot td             { font-weight: 700; background: #f8fafc; font-family: 'DM Mono';
                                      border-top: 1.5px solid #e2e8f0 !important; border-bottom: 1.5px solid #e2e8f0 !important; }
    .cf-table tr.sub td             { font-weight: 700; background: #f8fafc;
                                      border-top: 1.5px solid #e2e8f0 !important; border-bottom: none !important; }
    .cf-table tr.ind td             { color: #64748b; }
    .cf-table tr.ind td:first-child { padding-left: 20px; }
    .cf-table tr.closing td         { font-weight: 700; background: #0b1e3a; color: #fff; font-family: 'DM Mono';
                                      border-top: 1.5px solid #e2e8f0 !important; }
    .cf-table tr.closing td:first-child { font-family: 'DM Sans'; }


    /* ── Finance slides — prefix .fp4- / inline classes from source ── */
    .slide-header { padding: 13px var(--slide-pad-x); }
    .sh-title {
      font-family: 'DM Sans', sans-serif;
      font-size: 15px; font-weight: 600; color: #fff;
      line-height: 1.25; max-width: 660px;
    }
    .sh-right { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
    .sh-period {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; font-weight: 500; color: var(--color-teal); white-space: nowrap;
    }
    .sh-num {
      font-family: 'DM Mono', monospace;
      font-size: 10px; font-weight: 500; color: rgba(255,255,255,.30); white-space: nowrap;
    }
    .slide-body { padding: 10px var(--slide-pad-x) 8px; flex: 1; overflow: hidden; display: flex; flex-direction: column; gap: 8px; }
    .slide-footer { padding: 6px var(--slide-pad-x); background: var(--color-surface); border-top: 1px solid var(--color-border); }
    .footer-brand { font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 500; color: var(--color-border); }
    .footer-page  { font-family: 'DM Sans', sans-serif; font-size: 10px; font-weight: 500; color: var(--color-neutral); }

    /* ── Dashboard table ── */
    .dt { width: 100%; border-collapse: collapse; }
    .dt thead tr { background: var(--color-navy); }
    .dt thead th { padding: 5px 7px; text-align: right; font-family: 'Inter', sans-serif; font-size: 8px; font-weight: 700; color: #94a3b8; white-space: nowrap; letter-spacing: .4px; text-transform: uppercase; }
    .dt thead th:first-child { text-align: left; padding-left: 10px; color: #fff; min-width: 140px; }
    .dt thead th.tha { color: #fff; }
    .dt thead th.thh { background: #1e3a5f; color: #7dd3fc; }
    .dt thead th.thb { background: #263d5f; color: #93c5fd; }
    .dt tr.rs td { padding: 4px 7px 2px; font-family: 'Inter', sans-serif; font-size: 8px; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: 1.2px; background: var(--color-surface); border-top: 2px solid var(--color-border); }
    .dt tr.rs td:first-child { padding-left: 10px; }
    .dt tr.rb td { padding: 3px 7px; font-weight: 700; background: var(--color-bg); font-size: 9.5px; border-top: 1px solid var(--color-border); }
    .dt tr.rb td:first-child { padding-left: 10px; font-family: 'DM Sans', sans-serif; display: flex; align-items: center; gap: 5px; }
    .dt tr.rb td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; }
    .dt tr.rv td { padding: 3px 7px; background: var(--color-bg); font-size: 9.5px; border-top: 1px solid var(--color-border); }
    .dt tr.rv td:first-child { padding-left: 18px; font-family: 'DM Sans', sans-serif; color: var(--color-text-secondary); display: flex; align-items: center; gap: 5px; }
    .dt tr.rv td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; color: var(--color-text-secondary); }
    .dt tr.rp td { padding: 1px 7px 2px; background: var(--color-bg); font-family: 'Inter', sans-serif; font-size: 8.5px; border-top: none; }
    .dt tr.rp td:first-child { padding-left: 22px; color: var(--color-neutral); font-style: italic; }
    .dt tr.rp td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; color: var(--color-neutral); font-style: italic; }
    .dt tr.rt td { padding: 3px 7px; background: var(--color-surface); font-family: 'Inter', sans-serif; font-size: 8.5px; font-weight: 600; border-top: 1px solid var(--color-border); }
    .dt tr.rt td:first-child { padding-left: 10px; color: var(--color-neutral); }
    .dt tr.rt td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; color: var(--color-neutral); }
    .dt tr.re td { padding: 4px 7px; font-weight: 700; background: #0b1e3a; color: #fff; font-size: 9.5px; border-top: 2px solid #1e3a5f; }
    .dt tr.re td:first-child { padding-left: 10px; font-family: 'DM Sans', sans-serif; }
    .dt tr.re td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; }
    .dt tr.rem td { padding: 1px 7px 3px; background: #0b1e3a; font-family: 'Inter', sans-serif; font-size: 8.5px; font-style: italic; border-top: none; }
    .dt tr.rem td:first-child { padding-left: 22px; color: #475569; }
    .dt tr.rem td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; color: #475569; }
    .dt tr.rsp td { height: 4px; background: var(--color-bg); border: none; }
    .dt tr.r40 td { padding: 3px 7px; font-weight: 700; background: var(--color-teal-light); font-size: 9.5px; border-top: 2px solid var(--color-teal); }
    .dt tr.r40 td:first-child { padding-left: 10px; font-family: 'DM Sans', sans-serif; color: var(--color-teal); }
    .dt tr.r40 td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; color: var(--color-text-primary); }
    .dt tr.rca td { padding: 3px 7px; font-weight: 600; background: var(--color-surface); font-size: 9.5px; border-top: 1px solid var(--color-border); }
    .dt tr.rca td:first-child { padding-left: 10px; font-family: 'DM Sans', sans-serif; color: var(--color-text-secondary); display: flex; align-items: center; gap: 5px; }
    .dt tr.rca td:not(:first-child) { font-family: 'DM Mono', monospace; text-align: right; color: var(--color-text-secondary); }

    /* ── Dots ── */
    .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; display: inline-block; }
    .dot-teal  { background: var(--color-teal); }
    .dot-green { background: #1D9E75; }
    .dot-gray  { background: #94a3b8; }
    .dot-navy  { background: #334155; }

    /* ── Delta badges ── */
    .db { display: inline-flex; align-items: center; gap: 2px; font-family: 'DM Mono', monospace; font-size: 8.5px; font-weight: 600; padding: 1px 5px; border-radius: 99px; }
    .db.p  { color: #185FA5; background: #dbeafe; }
    .db.n  { color: #E87722; background: #fff7ed; }
    .db.z  { color: var(--color-neutral); background: var(--color-surface); }
    .db.pp { color: #185FA5; background: transparent; }
    .db.np { color: #E87722; background: transparent; }

    /* ── Chart wrap ── */
    .chart-wrap { position: relative; width: 100%; }
    .chart-wrap canvas { display: block; width: 100% !important; }

    /* ── Section label ── */
    .sec-label { font-family: 'Inter', sans-serif; font-size: 8.5px; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: 1.5px; }

    /* ── Comments box ── */
    .comments-box { background: var(--color-surface); border-radius: 8px; padding: 10px 12px; display: flex; flex-direction: column; gap: 7px; }
    .comment-item { display: flex; gap: 7px; align-items: flex-start; font-family: 'Inter', sans-serif; font-size: 10.5px; line-height: 1.55; color: var(--color-text-secondary); }
    .comment-dot  { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
    .comment-item b { color: var(--color-text-primary); }

    /* ── Cash Flow table ── */
    .cf-table { width: 100%; border-collapse: collapse; }
    .cf-table thead th { background: var(--color-navy); color: #94a3b8; padding: 5px 7px; text-align: right; font-family: 'Inter', sans-serif; font-size: 8px; font-weight: 700; text-transform: uppercase; white-space: nowrap; }
    .cf-table thead th:first-child { text-align: left; padding-left: 10px; color: #fff; }
    .cf-table thead th.tha { color: #fff; }
    .cf-table td { padding: 3px 7px; text-align: right; font-family: 'DM Mono', monospace; font-size: 9.5px; border-top: 1px solid var(--color-border); }
    .cf-table td:first-child { text-align: left; padding-left: 10px; font-family: 'Inter', sans-serif; white-space: nowrap; font-size: 9.5px; }
    .cf-table tr.tot td     { font-weight: 700; background: #f0fdf4; }
    .cf-table tr.sub td     { font-weight: 700; background: var(--color-surface); }
    .cf-table tr.ind td     { color: var(--color-text-secondary); }
    .cf-table tr.ind td:first-child { padding-left: 20px; }
    .cf-table tr.closing td { font-weight: 700; background: var(--color-navy); color: #fff; }
    .cf-table tr.closing td:first-child { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body>

  <!-- ============================================================
       SLIDE 1 — Section Cover
       ============================================================ -->
  <div class="slide section-cover">
    <div class="eyebrow">Section 04</div>
    <div class="section-title">Financial<br>Performance</div>
    <div class="section-sub">P&amp;L · OpEx · Revenue Bridge · Cash Flow</div>
    <div class="slide-num">1</div>
  </div>

  <div class="slide-divider">↓</div>

  <!-- ============================================================
       SLIDE 2 — P&L Quarterly vs Prior Year
       ============================================================ -->
  <div class="slide">
    <div class="slide-header">
      <div class="sh-title">EBITDA margin improved from −14.8pp in Q1 2025 to +10.3pp in Q1 2026 — 25pp expansion in one year</div>
      <div class="sh-right">
        <div class="sh-period">P&amp;L Quarterly · vs Prior Year</div>
        <div class="sh-num">02 / 07</div>
      </div>
    </div>
    <div class="slide-body">
      <table class="dt">
        <thead>
          <tr>
            <th style="min-width:148px">(kUSD)</th>
            <th>Q1 2025</th><th>Q2 2025</th><th>Q3 2025</th><th>Q4 2025</th>
            <th class="thh">Q1 2026</th>
            <th class="tha">YoY Δ</th>
          </tr>
        </thead>
        <tbody>
          <tr class="rs"><td colspan="7">ARR</td></tr>
          <tr class="rb">
            <td><span class="dot dot-teal"></span><b>ARR EoP ($M)</b></td>
            <td>22.73</td><td>23.34</td><td>24.70</td><td>27.30</td>
            <td style="background:#e0f2fe"><b>28.26</b></td>
            <td><span class="db p">+24.3%</span></td>
          </tr>
          <tr class="rp">
            <td>ARR Growth YoY</td>
            <td>40%</td><td>41%</td><td>32%</td><td>40%</td>
            <td style="background:#e0f2fe">24%</td><td>—</td>
          </tr>
          <tr class="rs"><td colspan="7">P&amp;L</td></tr>
          <tr class="rb">
            <td><span class="dot dot-teal"></span><b>Revenue</b></td>
            <td>5,257</td><td>5,632</td><td>6,040</td><td>6,560</td>
            <td style="background:#e0f2fe"><b>6,920</b></td>
            <td><span class="db p">+31.6%</span></td>
          </tr>
          <tr class="rb">
            <td><span class="dot dot-teal"></span><b>Gross Profit</b></td>
            <td>4,254</td><td>4,593</td><td>4,931</td><td>5,419</td>
            <td style="background:#e0f2fe"><b>5,665</b></td>
            <td><span class="db p">+33.2%</span></td>
          </tr>
          <tr class="rp">
            <td>Gross Margin %</td>
            <td>80.9%</td><td>81.6%</td><td>81.6%</td><td>82.6%</td>
            <td style="background:#e0f2fe">81.9%</td>
            <td><span class="db pp">+1.0pp</span></td>
          </tr>
          <tr class="rv"><td><span class="dot dot-green"></span>S&amp;M</td><td>2,595</td><td>2,482</td><td>2,362</td><td>2,114</td><td style="background:#e0f2fe">2,027</td><td><span class="db p">−21.9%</span></td></tr>
          <tr class="rv"><td><span class="dot dot-gray"></span>R&amp;D</td><td>1,464</td><td>1,564</td><td>1,641</td><td>1,952</td><td style="background:#e0f2fe">1,865</td><td><span class="db n">+27.4%</span></td></tr>
          <tr class="rv"><td><span class="dot dot-teal"></span>G&amp;A</td><td>970</td><td>976</td><td>904</td><td>1,013</td><td style="background:#e0f2fe">1,064</td><td><span class="db n">+9.7%</span></td></tr>
          <tr class="rb"><td><span class="dot dot-navy"></span><b>Total OpEx</b></td><td>5,030</td><td>5,021</td><td>4,907</td><td>5,079</td><td style="background:#e0f2fe"><b>4,955</b></td><td><span class="db p">−1.5%</span></td></tr>
