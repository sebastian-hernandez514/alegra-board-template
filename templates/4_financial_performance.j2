          <div style="display:flex;gap:12px">
            <span style="display:flex;align-items:center;gap:3px;font-family:'Inter',sans-serif;font-size:8.5px;color:var(--color-neutral)"><span style="width:8px;height:8px;background:#1D9E75;border-radius:2px;display:inline-block"></span>Net accumulation</span>
            <span style="display:flex;align-items:center;gap:3px;font-family:'Inter',sans-serif;font-size:8.5px;color:var(--color-neutral)"><span style="width:8px;height:8px;background:#E87722;border-radius:2px;display:inline-block"></span>Net burn</span>
          </div>
          <div class="comments-box" style="margin-top:2px">
            <div class="comment-item" style="font-size:10px"><span class="comment-dot" style="background:#1D9E75"></span><span><b>Q1 2026 records the lowest quarterly burn: −$126K</b> (Jan −$944K + Feb +$455K + Mar +$363K), an improvement of +$415K vs Q1 2025 (−$541K).</span></div>
            <div class="comment-item" style="font-size:10px"><span class="comment-dot" style="background:#14b8a6"></span><span><b>Burn reduction is consistent since Q1 25</b>: −$541K → −$349K → −$275K → −$587K (Q4 annual concentration) → −$126K in Q1 26.</span></div>
          </div>
        </div>
      </div>
    </div>
    <div class="slide-footer">
      <span class="footer-brand">Alegra · Confidential</span>
      <span class="footer-page">7</span>
    </div>
  </div>

  <script>
  (function(){
    Chart.defaults.font.family = 'Inter';
    Chart.defaults.color = '#94a3b8';

    const BS = {
      x: { grid:{display:false}, border:{display:false}, ticks:{font:{size:8,family:'Inter'},color:'#94a3b8'} },
      y: { grid:{color:'rgba(128,128,128,.07)'}, border:{display:false}, ticks:{font:{size:8,family:'DM Mono'},color:'#94a3b8'} },
    };

    /* SLIDE 4: OpEx Stacked Bar */
    new Chart(document.getElementById('ch-opex-stacked'), {
      type: 'bar',
      data: {
        labels: ['Actuals','Budget','Y-1 (2025)'],
        datasets: [
          { label:'S&M', data:[2027,2439,2595], backgroundColor:'#1D9E75', borderRadius:0, stack:'s' },
          { label:'R&D', data:[1865,1915,1464], backgroundColor:'#94a3b8', borderRadius:0, stack:'s' },
          { label:'G&A', data:[1064,1103,970],  backgroundColor:'#14b8a6', borderRadius:3,  stack:'s' },
        ]
      },
      options: {
        responsive:true, maintainAspectRatio:false,
        plugins: { legend:{display:false}, tooltip:{enabled:false} },
        scales: { x:BS.x, y:{...BS.y, stacked:true, ticks:{...BS.y.ticks, callback:v=>`$${v}K`}, max:6200} }
      },
      plugins: [{
        id:'totals',
        afterDatasetsDraw(chart) {
          const {ctx,scales:{x,y}} = chart;
          const totals = [4955,5456,5030];
          ctx.save();
          ctx.font = "bold 10px 'DM Mono'";
          ctx.fillStyle = '#0f172b';
          ctx.textAlign = 'center';
          totals.forEach((t,i) => ctx.fillText(`${t.toLocaleString()}`, x.getPixelForValue(i), y.getPixelForValue(t)-5));
          ctx.restore();
        }
      }]
    });

    /* SLIDE 5: Revenue Bridge Waterfall */
    (function(){
      const steps = [
        {l:'Net Rev −1',    v:2290, type:'base'},
        {l:'Recovered P−1', v:  60, type:'pos'},
        {l:'New Logos',     v: 140, type:'pos'},
        {l:'Reactivated',   v:  30, type:'pos'},
        {l:'Recovered',     v:  20, type:'pos'},
        {l:'Upgrades',      v:  25, type:'pos'},
        {l:'Efficiencies',  v: -35, type:'neg'},
        {l:'Churn',         v: -70, type:'neg'},
        {l:'Down+Mora',     v: -50, type:'neg'},
        {l:'Opened cycles', v:  90, type:'pos'},
        {l:'FX Rate',       v:  35, type:'pos'},
        {l:'Subs. plans',   v: -16, type:'neg'},
        {l:'Cierre Mar',    v:2419, type:'close'},
      ];
      let run = 0;
      const fd=[], colors=[], labels=steps.map(s=>s.l);
      steps.forEach(s => {
        if(s.type==='base')        { fd.push([0,s.v]); colors.push('#14b8a6'); run=s.v; }
        else if(s.type==='close')  { fd.push([0,s.v]); colors.push('#14b8a6'); }
        else { const st=run, en=run+s.v; fd.push([Math.min(st,en),Math.max(st,en)]); colors.push(s.type==='pos'?'#1D9E75':'#C2410C'); run=en; }
      });
      new Chart(document.getElementById('ch-bridge'), {
        type: 'bar',
        data: { labels, datasets:[{label:'Bridge', data:fd, backgroundColor:colors, borderRadius:3, barPercentage:.55}] },
        options: {
          responsive:true, maintainAspectRatio:false,
          plugins: { legend:{display:false}, tooltip:{enabled:false} },
          scales: {
            x: {...BS.x, ticks:{font:{size:8}, color:'#94a3b8', maxRotation:40}},
            y: {...BS.y, min:2100, max:2700, ticks:{...BS.y.ticks, callback:v=>`$${v}K`}}
          }
        }
      });
    })();

    /* SLIDE 7: Cash Balance by Quarter */
    (function(){
      const labels = ['Q1 25','Q2 25','Q3 25','Q4 25','Q1 26','Q2 26B','Q3 26B','Q4 26B'];
      const actual = [5434,5086,4811,4223,4097,null,null,null];
      const budget = [null,null,null,null,2100,1984,2308,2732];
      new Chart(document.getElementById('ch-saldo'), {
        type: 'line',
        data: { labels, datasets: [
          { label:'Actual', data:actual, borderColor:'#14b8a6', backgroundColor:'rgba(20,184,166,.10)', borderWidth:2, pointRadius:4, pointBackgroundColor:'#14b8a6', tension:.35, fill:true, spanGaps:false },
          { label:'Budget', data:budget, borderColor:'#534AB7', backgroundColor:'transparent', borderWidth:1.5, borderDash:[4,3], pointRadius:3, pointBackgroundColor:'#534AB7', tension:.35, spanGaps:false },
        ]},
        options: {
          responsive:true, maintainAspectRatio:false,
          plugins: { legend:{display:false}, tooltip:{enabled:false} },
          scales: { x:BS.x, y:{...BS.y, ticks:{...BS.y.ticks, callback:v=>`$${v}K`}} }
        }
      });
    })();

    /* SLIDE 7: Cash Burn by Quarter */
    (function(){
      const labels = ['Q1 25','Q2 25','Q3 25','Q4 25','Q1 26'];
      const data   = [-541,-349,-275,-587,-126];
      const colors = data.map(v => v>=0 ? '#1D9E75' : '#E87722');
      new Chart(document.getElementById('ch-burn'), {
        type: 'bar',
        data: { labels, datasets:[{label:'Burn', data, backgroundColor:colors, borderRadius:4, barPercentage:.55}] },
        options: {
          responsive:true, maintainAspectRatio:false,
          plugins: { legend:{display:false}, tooltip:{enabled:false} },
          scales: { x:BS.x, y:{...BS.y, ticks:{...BS.y.ticks, callback:v=>`${v>=0?'+':''}${v}K`}} }
        }
      });
    })();
  })();
  </script>

</body>
</html>
